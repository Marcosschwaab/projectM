# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore bundler config
/.bundle

# Ignore database configuration
config/database.yml

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore assets compiled by Rails
/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore coverage reports
/coverage/

# Ignore Kamal secrets
.kamal/secrets

# User's Claude Code / opencode configuration (separate from project)
/claude/
/CLAUDE.md
/AGENTS.md

# Ignore node_modules (from @rails/actioncable pin)
node_modules/


# Old wrong-named model
/app/models/strategic_canva.rb

/app/assets/builds/*
!/app/assets/builds/.keep
