<div class="mb-6">
  <%= link_to organization_program_path(@organization, @program), class: "text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 mb-2 inline-block" do %>
    ← <%= t("actions.back_to_program") %>
  <% end %>
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("programs.edit") %></h1>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
  <%= render "form", program: @program %>
</div>
