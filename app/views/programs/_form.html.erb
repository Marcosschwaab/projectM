<%= form_with(model: [@organization, @program], data: { turbo: false }) do |f| %>
  <% if @program.errors.any? %>
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm dark:bg-red-900/30 dark:border-red-800 dark:text-red-400">
      <h2 class="font-semibold mb-1"><%= pluralize(@program.errors.count, t("errors.error", count: @program.errors.count)) %> <%= t("errors.prohibited", model: t("programs.title").downcase) %></h2>
      <ul class="list-disc pl-4 space-y-1">
        <% @program.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
      <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.select :status, Program::STATUSES.map { |s| [t("projects.statuses.#{s}"), s] }, { include_blank: true }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div>
        <%= f.label :color, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.color_field :color, class: "w-full h-10 px-1 py-1 border border-gray-300 rounded-lg cursor-pointer bg-white dark:bg-gray-700 dark:border-gray-600" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.date_field :start_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div>
        <%= f.label :end_date, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.date_field :end_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
    </div>

    <div>
      <%= f.label :budget, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
      <%= f.number_field :budget, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
    </div>
  </div>

  <div class="flex items-center gap-3 mt-6">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
    <%= link_to t("actions.cancel"), organization_programs_path(@organization), class: "px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition-colors dark:text-gray-400 dark:hover:bg-gray-700" %>
  </div>
<% end %>
