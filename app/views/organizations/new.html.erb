<div class="mb-6">
  <%= link_to organizations_path, class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_organizations") %>
  <% end %>
</div>

<div class="max-w-2xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 dark:bg-gray-800 dark:border-gray-700">
    <h1 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("organizations.new") %></h1>

    <%= form_with(model: @organization, data: { turbo: false }) do |f| %>
      <% if @organization.errors.any? %>
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm dark:bg-red-900/30 dark:border-red-800 dark:text-red-400">
          <h2 class="font-semibold mb-1"><%= pluralize(@organization.errors.count, t("errors.error", count: @organization.errors.count)) %> <%= t("errors.prohibited", model: t("organizations.title").downcase) %></h2>
          <ul class="list-disc pl-4 space-y-1">
            <% @organization.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.text_field :name, placeholder: t("organizations.name_placeholder"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div>
          <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.text_area :description, rows: 3, placeholder: t("organizations.description_placeholder"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div class="flex items-center gap-2">
          <%= f.check_box :allow_auto_join, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:text-indigo-400" %>
          <%= f.label :allow_auto_join, t("organizations.allow_auto_join"), class: "text-sm text-gray-600 dark:text-gray-400" %>
        </div>

        <div class="flex items-center gap-4 pt-2">
          <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer dark:bg-indigo-500 dark:hover:bg-indigo-600" %>
          <%= link_to t("actions.cancel"), organizations_path, class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
