<div class="mb-6">
  <%= link_to organizations_path, class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_organizations") %>
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 dark:bg-gray-800 dark:border-gray-700">
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center flex-shrink-0 dark:bg-indigo-900/30">
        <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400"><%= @organization.name.first.upcase %></span>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @organization.name %></h1>
        <p class="text-sm text-gray-500 mt-0.5 dark:text-gray-400"><%= @organization.description.presence || t("organizations.no_description") %></p>
      </div>
    </div>
    <%= link_to edit_organization_path(@organization), class: "px-3 py-1.5 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" do %>
      <%= t("actions.edit") %>
    <% end %>
  </div>

  <div class="grid grid-cols-3 gap-4">
    <div class="p-3 bg-gray-50 rounded-lg text-center dark:bg-gray-700/50">
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @organization.members.count %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("organizations.members") %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg text-center dark:bg-gray-700/50">
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @organization.projects.count %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("projects.title") %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg text-center dark:bg-gray-700/50">
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @organization.okr_cycles.count %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("okrs.title") %></p>
    </div>
  </div>
</div>

<div class="flex items-center gap-3 mb-6">
  <%= link_to organization_tags_path(@organization), class: "px-3 py-1.5 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" do %>
    <%= t("tags.title") %>
  <% end %>
  <%= link_to organization_webhooks_path(@organization), class: "px-3 py-1.5 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" do %>
    <%= t("webhooks.title") %>
  <% end %>
  <%= link_to organization_custom_fields_path(@organization), class: "px-3 py-1.5 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" do %>
    <%= t("custom_fields.title") %>
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
  <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("organizations.members") %></h2>
    <%= link_to new_organization_invitation_path(@organization), class: "px-3 py-1.5 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600" do %>
      + <%= t("organizations.invite") %>
    <% end %>
  </div>
  <div class="divide-y divide-gray-100 dark:divide-gray-700">
    <% @organization.memberships.includes(:user).each do |membership| %>
      <div class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors dark:hover:bg-gray-700/50">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center flex-shrink-0 dark:bg-indigo-900/30">
            <span class="text-xs font-medium text-indigo-600 dark:text-indigo-400"><%= membership.user.name.first.upcase %></span>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= membership.user.name %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= membership.user.email %></p>
          </div>
        </div>
        <span class="<%= role_badge_class(membership.role) %>"><%= membership.role.humanize %></span>
      </div>
    <% end %>
  </div>
</div>
