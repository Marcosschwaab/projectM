<%= render "shared/project_nav" %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @matrix.name %></h1>
    <%= link_to t("actions.edit"), edit_organization_project_project_matrix_path(@organization, @project, @matrix), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700" %>
  </div>

  <% if @matrix.matrix_columns.any? && @matrix.matrix_rows.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full border-collapse border border-gray-300 dark:border-gray-600">
        <thead>
          <tr>
            <th class="border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase"></th>
            <% @matrix.matrix_columns.each do |col| %>
              <th class="border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 px-3 py-2 text-left text-xs font-medium text-gray-700 dark:text-gray-300"><%= col.name %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @matrix.matrix_rows.each do |row| %>
            <tr>
              <td class="border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 px-3 py-2 text-xs font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><%= row.name %></td>
              <% @matrix.matrix_columns.each do |col| %>
                <% cell = @matrix.matrix_cells.find { |c| c.matrix_column_id == col.id && c.matrix_row_id == row.id } %>
                <td class="border border-gray-300 dark:border-gray-600 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"><%= cell&.value %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("matrices.empty") %></p>
      <%= link_to t("matrices.edit_structure"), edit_organization_project_project_matrix_path(@organization, @project, @matrix), class: "mt-2 inline-block text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %>
    </div>
  <% end %>
</div>
