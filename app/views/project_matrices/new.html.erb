<div class="mb-6">
  <%= link_to organization_project_project_matrices_path(@organization, @project), class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_matrices") %>
  <% end %>
</div>

<div class="max-w-lg">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 dark:bg-gray-800 dark:border-gray-700">
    <h1 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("matrices.new") %></h1>

    <%= form_with(model: [@organization, @project, @matrix], data: { turbo: false }) do |f| %>
      <div class="mb-4">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div class="flex items-center gap-4">
        <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 cursor-pointer" %>
        <%= link_to t("actions.cancel"), organization_project_project_matrices_path(@organization, @project), class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm dark:border-gray-600 dark:text-gray-300" %>
      </div>
    <% end %>
  </div>
</div>
