<%= render "shared/project_nav" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("matrices.title") %></h1>
  <%= link_to t("matrices.new"), new_organization_project_project_matrix_path(@organization, @project), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700" %>
</div>

<% if @matrices.any? %>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    <% @matrices.each do |matrix| %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= link_to matrix.name, [@organization, @project, matrix], class: "hover:text-indigo-600 dark:hover:text-indigo-400" %></h2>
          <div class="flex items-center gap-1">
            <%= link_to edit_organization_project_project_matrix_path(@organization, @project, matrix), class: "p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            <% end %>
            <%= button_to [@organization, @project, matrix], method: :delete, data: { confirm: t("actions.confirm_delete") }, class: "p-1 text-gray-400 hover:text-red-600 dark:hover:text-red-400 cursor-pointer transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            <% end %>
          </div>
        </div>
        <p class="text-xs text-gray-400"><%= matrix.matrix_columns.count %> <%= t("matrices.columns").downcase %>, <%= matrix.matrix_rows.count %> <%= t("matrices.rows").downcase %></p>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-12">
    <svg class="mx-auto w-16 h-16 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
    <p class="mt-4 text-sm text-gray-500 dark:text-gray-400"><%= t("matrices.no_matrices") %></p>
    <%= link_to t("matrices.create_first"), new_organization_project_project_matrix_path(@organization, @project), class: "mt-2 inline-block text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %>
  </div>
<% end %>
