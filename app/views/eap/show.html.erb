<%= render "shared/project_nav" %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("eap.title") %></h1>
  </div>

  <%# Legend %>
  <div class="flex flex-wrap gap-3 mb-6 text-xs">
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-500"></span> <%= t("eap.statuses.on_time") %></span>
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-yellow-500"></span> <%= t("eap.statuses.at_risk") %></span>
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-500"></span> <%= t("eap.statuses.overdue") %></span>
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-gray-400"></span> <%= t("eap.statuses.suspended") %></span>
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-purple-500"></span> <%= t("eap.statuses.milestone") %></span>
  </div>

  <% if @root_items.any? %>
    <div class="space-y-2">
      <% @root_items.each do |item| %>
        <%= render "eap/eap_item", item: item, children: @items_by_parent[item[:id]], level: 0 %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto w-16 h-16 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      <p class="mt-4 text-sm text-gray-500 dark:text-gray-400"><%= t("eap.empty") %></p>
    </div>
  <% end %>
</div>
