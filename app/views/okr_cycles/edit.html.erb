<div class="mb-6">
  <%= link_to [@organization, @cycle], class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_cycle") %>
  <% end %>
</div>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("okrs.edit_cycle") %></h1>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <%= form_with(model: [@organization, @cycle], class: "space-y-4") do |f| %>
      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.date_field :start_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :end_date, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.date_field :end_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
      </div>
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.select :status, OkrCycle.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div class="flex items-center gap-3 pt-2">
        <%= f.submit t("actions.update"), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 cursor-pointer border-none dark:bg-indigo-500 dark:hover:bg-indigo-600" %>
        <%= link_to t("actions.cancel"), [@organization, @cycle], class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" %>
      </div>
    <% end %>
  </div>
</div>
