<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("webhooks.title") %></h1>
  <%= link_to new_organization_webhook_path(@organization), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:bg-indigo-500 dark:hover:bg-indigo-600" do %>
    + <%= t("webhooks.new") %>
  <% end %>
</div>

<div class="space-y-4">
  <% @webhooks.each do |webhook| %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
      <div class="px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="w-2.5 h-2.5 rounded-full <%= webhook.active ? "bg-green-500" : "bg-gray-400" %>"></span>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= webhook.name %></h3>
            <p class="text-xs text-gray-500 mt-0.5 dark:text-gray-400"><%= webhook.url %></p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <%= link_to t("actions.view"), organization_webhook_path(@organization, webhook), class: "text-xs text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %>
          <%= link_to t("actions.edit"), edit_organization_webhook_path(@organization, webhook), class: "text-xs text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %>
          <%= button_to t("actions.delete"), organization_webhook_path(@organization, webhook), method: :delete, data: { turbo_confirm: t("actions.confirm_delete") }, class: "text-xs text-red-600 hover:text-red-700 bg-transparent border-none cursor-pointer dark:text-red-400 dark:hover:text-red-300" %>
        </div>
      </div>
      <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center gap-4 text-xs text-gray-500 dark:bg-gray-700/50 dark:border-gray-700 dark:text-gray-400">
        <span><%= t("webhooks.events_count", count: webhook.events.size) %></span>
        <span><%= t("webhooks.deliveries_count", count: webhook.delivery_count) %></span>
      </div>
    </div>
  <% end %>

  <% if @webhooks.empty? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center dark:bg-gray-800 dark:border-gray-700">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-3 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
      <p class="text-gray-500 dark:text-gray-400"><%= t("webhooks.no_webhooks") %></p>
    </div>
  <% end %>
</div>
