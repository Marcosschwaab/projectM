<div class="mb-6">
  <%= link_to organization_webhooks_path(@organization), class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_webhooks") %>
  <% end %>
</div>

<div class="max-w-2xl space-y-6">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <span class="w-3 h-3 rounded-full <%= @webhook.active ? "bg-green-500" : "bg-gray-400" %>"></span>
        <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= @webhook.name %></h1>
      </div>
      <%= link_to edit_organization_webhook_path(@organization, @webhook), class: "px-3 py-1.5 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" do %>
        <%= t("actions.edit") %>
      <% end %>
    </div>

    <div class="grid grid-cols-2 gap-4 text-sm">
      <div>
        <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("webhooks.fields.url") %></p>
        <p class="text-gray-900 font-mono break-all dark:text-gray-100"><%= @webhook.url %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("webhooks.fields.secret") %></p>
        <p class="text-gray-900 font-mono text-xs break-all dark:text-gray-100"><%= @webhook.secret %></p>
      </div>
    </div>

    <div class="mt-4">
      <p class="text-xs text-gray-500 mb-2 dark:text-gray-400"><%= t("webhooks.fields.events") %></p>
      <div class="flex flex-wrap gap-2">
        <% @webhook.event_types.each do |event| %>
          <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= @webhook.events.include?(event) ? "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400" : "bg-gray-100 text-gray-400 dark:bg-gray-700 dark:text-gray-500" %>">
            <%= event %>
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("webhooks.deliveries") %></h2>
    </div>
    <% if @webhook.deliveries.any? %>
      <div class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @webhook.deliveries.order(created_at: :desc).limit(20).each do |delivery| %>
          <div class="px-6 py-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full <%= delivery.status == 200 ? "bg-green-500" : delivery.status == 0 ? "bg-red-500" : "bg-yellow-500" %>"></span>
                <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= delivery.status %></span>
                <span class="text-xs text-gray-400"><%= t("time.ago", time: time_ago_in_words(delivery.created_at)) %></span>
              </div>
              <% if delivery.error.present? %>
                <span class="text-xs text-red-500"><%= delivery.error %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-6 text-center">
        <p class="text-sm text-gray-400 dark:text-gray-500"><%= t("webhooks.no_deliveries") %></p>
      </div>
    <% end %>
  </div>
</div>
