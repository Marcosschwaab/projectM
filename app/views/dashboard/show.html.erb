<div data-controller="dashboard" class="max-w-full">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("dashboard.title") %></h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= l(Time.current, format: :dashboard) %></p>
    </div>
    <div class="flex items-center gap-2">
      <button type="button"
              data-action="click->dashboard#addWidget"
              class="px-3 py-2 text-sm font-medium bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors dark:bg-indigo-500 dark:hover:bg-indigo-600 flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        <%= t("dashboard.add_widget") %>
      </button>
    </div>
  </div>

  <div class="dashboard-grid" data-dashboard-target="grid">
    <% @widgets.each do |widget| %>
      <div class="dashboard-grid-item relative <%= widget.width == 3 ? 'lg:col-span-3' : widget.width == 2 ? 'lg:col-span-2' : 'lg:col-span-1' %> col-span-1">
        <%= render "dashboard/widget", widget: widget %>
        <div class="dashboard-settings hidden absolute right-0 top-0 mt-12 w-64 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 p-4 z-50"
             data-dashboard-target="settingsPanel">
          <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 dark:text-gray-400"><%= t("dashboard.widget_size") %></h4>
          <div class="flex items-center gap-2">
            <button type="button"
                    data-width="1"
                    data-action="click->dashboard#setWidth"
                    class="flex-1 px-3 py-2 text-xs font-medium rounded-lg border transition-colors <%= widget.width == 1 ? 'bg-indigo-50 border-indigo-300 text-indigo-700 dark:bg-indigo-900/30 dark:border-indigo-600 dark:text-indigo-300' : 'border-gray-200 text-gray-600 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700' %>">
              <svg class="w-4 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
              <%= t("dashboard.size_small") %>
            </button>
            <button type="button"
                    data-width="2"
                    data-action="click->dashboard#setWidth"
                    class="flex-1 px-3 py-2 text-xs font-medium rounded-lg border transition-colors <%= widget.width == 2 ? 'bg-indigo-50 border-indigo-300 text-indigo-700 dark:bg-indigo-900/30 dark:border-indigo-600 dark:text-indigo-300' : 'border-gray-200 text-gray-600 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700' %>">
              <svg class="w-5 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
              <%= t("dashboard.size_medium") %>
            </button>
            <button type="button"
                    data-width="3"
                    data-action="click->dashboard#setWidth"
                    class="flex-1 px-3 py-2 text-xs font-medium rounded-lg border transition-colors <%= widget.width == 3 ? 'bg-indigo-50 border-indigo-300 text-indigo-700 dark:bg-indigo-900/30 dark:border-indigo-600 dark:text-indigo-300' : 'border-gray-200 text-gray-600 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700' %>">
              <svg class="w-6 h-4 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
              <%= t("dashboard.size_large") %>
            </button>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
