<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("dashboard.title") %></h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= l(Time.current, format: :dashboard) %></p>
  </div>
</div>

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:bg-gray-800 dark:border-gray-700 border-t-2 border-t-indigo-500">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.active_projects") %></span>
      <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
    </div>
    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @active_projects_count %></p>
    <div class="mt-3 w-full h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
      <div class="h-full rounded-full bg-gradient-to-r from-indigo-500 to-indigo-400" style="width: <%= @projects.count > 0 ? (@active_projects_count.to_f / @projects.count * 100) : 0 %>%"></div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:bg-gray-800 dark:border-gray-700 border-t-2 border-t-green-500">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.done") %></span>
      <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <p class="text-3xl font-bold text-green-600 dark:text-green-400"><%= @completed_projects_count %></p>
    <div class="mt-3 w-full h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
      <div class="h-full rounded-full bg-gradient-to-r from-green-500 to-emerald-400" style="width: <%= @projects.count > 0 ? (@completed_projects_count.to_f / @projects.count * 100) : 0 %>%"></div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:bg-gray-800 dark:border-gray-700 border-t-2 border-t-blue-500">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.open_tasks") %></span>
      <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
    </div>
    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @open_tasks_count %></p>
    <div class="mt-3 w-full h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
      <div class="h-full rounded-full bg-gradient-to-r from-blue-500 to-blue-400" style="width: <%= @tasks.count > 0 ? (@open_tasks_count.to_f / @tasks.count * 100) : 0 %>%"></div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:bg-gray-800 dark:border-gray-700 border-t-2 border-t-red-500">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.overdue") %></span>
      <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <p class="text-3xl font-bold text-red-600 dark:text-red-400"><%= @overdue_tasks.count %></p>
    <div class="mt-3 w-full h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
      <div class="h-full rounded-full bg-gradient-to-r from-red-500 to-red-400" style="width: <%= @tasks.count > 0 ? (@overdue_tasks.count.to_f / @tasks.count * 100) : 0 %>%"></div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:bg-gray-800 dark:border-gray-700 border-t-2 border-t-purple-500">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.my_tasks") %></span>
      <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    </div>
    <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400"><%= @my_tasks.count %></p>
    <div class="mt-3 w-full h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
      <div class="h-full rounded-full bg-gradient-to-r from-purple-500 to-purple-400" style="width: <%= @tasks.count > 0 ? (@my_tasks.count.to_f / @tasks.count * 100) : 0 %>%"></div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:bg-gray-800 dark:border-gray-700 border-t-2 border-t-gray-400">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.team") %></span>
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    </div>
    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @members_count %></p>
    <p class="text-xs text-gray-400 mt-3"><%= t("dashboard.members") %></p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <h2 class="text-sm font-semibold text-gray-900 mb-5 dark:text-gray-100"><%= t("dashboard.completion_rate") %></h2>
    <div class="flex items-center justify-center">
      <div class="relative w-32 h-32">
        <svg class="w-32 h-32 -rotate-90" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="52" fill="none" stroke="#f3f4f6" stroke-width="10" class="dark:stroke-gray-700"/>
          <circle cx="60" cy="60" r="52" fill="none" stroke="<%= @completion_rate >= 75 ? '#10b981' : @completion_rate >= 50 ? '#f59e0b' : '#ef4444' %>" stroke-width="10"
                  stroke-dasharray="<%= 2 * Math::PI * 52 %>"
                  stroke-dashoffset="<%= 2 * Math::PI * 52 * (1 - @completion_rate.to_f / 100) %>"
                  stroke-linecap="round"/>
        </svg>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @completion_rate %>%</span>
        </div>
      </div>
    </div>
    <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700">
      <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
        <span><%= t("dashboard.tasks_completed") %></span>
        <span class="font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.tasks_completed_count", done: @tasks.where(status: :done).count, total: @tasks.count) %></span>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.tasks_by_status") %></h2>
    </div>
    <div class="space-y-4">
      <% Task.statuses.each do |status_name, _| %>
        <% count = @task_status_distribution[status_name] || 0 %>
        <% pct = @tasks.count > 0 ? (count.to_f / @tasks.count * 100).round(0) : 0 %>
        <div>
          <div class="flex items-center justify-between text-xs mb-1.5">
            <span class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style="background-color: <%= column_color(status_name) %>"></span>
              <span class="text-gray-600 dark:text-gray-400"><%= status_name.humanize %></span>
            </span>
            <span class="font-semibold text-gray-900 dark:text-gray-100"><%= count %></span>
          </div>
          <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
            <div class="h-full rounded-full transition-all duration-500" style="width: <%= pct %>%; background-color: <%= column_color(status_name) %>"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.tasks_by_priority") %></h2>
    </div>
    <div class="space-y-4">
      <% Task.priorities.each do |priority_name, _| %>
        <% count = @priority_distribution[priority_name] || 0 %>
        <% pct = @tasks.count > 0 ? (count.to_f / @tasks.count * 100).round(0) : 0 %>
        <div>
          <div class="flex items-center justify-between text-xs mb-1.5">
            <span class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full <%= priority_name == "urgent" ? "bg-red-500" : priority_name == "high" ? "bg-orange-500" : priority_name == "medium" ? "bg-blue-500" : "bg-gray-400" %>"></span>
              <span class="text-gray-600 dark:text-gray-400"><%= priority_name.humanize %></span>
            </span>
            <span class="font-semibold text-gray-900 dark:text-gray-100"><%= count %></span>
          </div>
          <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
            <div class="h-full rounded-full transition-all duration-500 <%= priority_name == "urgent" ? "bg-gradient-to-r from-red-500 to-red-400" : priority_name == "high" ? "bg-gradient-to-r from-orange-500 to-orange-400" : priority_name == "medium" ? "bg-gradient-to-r from-blue-500 to-blue-400" : "bg-gradient-to-r from-gray-400 to-gray-300" %>" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.project_status") %></h2>
    </div>
    <div class="p-6">
      <div class="space-y-4">
        <% Project.statuses.each do |status_name, _| %>
          <% count = @status_distribution[status_name] || 0 %>
          <% pct = @projects.count > 0 ? (count.to_f / @projects.count * 100).round(0) : 0 %>
          <div>
            <div class="flex items-center justify-between text-xs mb-1.5">
              <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full" style="background-color: <%= project_status_color(status_name) %>"></span>
                <span class="text-gray-600 dark:text-gray-400"><%= status_name.humanize %></span>
              </span>
              <span class="font-semibold text-gray-900 dark:text-gray-100"><%= count %></span>
            </div>
            <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
              <div class="h-full rounded-full transition-all duration-500" style="width: <%= pct %>%; background-color: <%= project_status_color(status_name) %>"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between dark:border-gray-700 bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.upcoming_deadlines") %></h2>
      <span class="text-xs font-medium text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded-full"><%= t("dashboard.this_week_count", count: @upcoming_tasks.count) %></span>
    </div>
    <div class="p-6">
      <% if @upcoming_tasks.any? %>
        <div class="space-y-2">
          <% @upcoming_tasks.each do |task| %>
            <%= link_to [@organization, task.project, task], class: "flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 transition-colors group dark:hover:bg-gray-700/50" do %>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-900 truncate group-hover:text-indigo-600 transition-colors dark:text-gray-100 dark:group-hover:text-indigo-400"><%= task.title %></p>
                <p class="text-xs text-gray-400 truncate mt-0.5"><%= task.project.name %></p>
              </div>
              <span class="text-xs font-semibold ml-3 px-2 py-1 rounded-full <%= task.due_date == Date.today ? "bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-400" : "bg-gray-50 text-gray-500 dark:bg-gray-700 dark:text-gray-400" %>">
                <%= task.due_date == Date.today ? t("time.today") : l(task.due_date, format: :short) %>
              </span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-8">
          <div class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-500"><%= t("calendar.no_deadlines") %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.my_tasks") %></h2>
    </div>
    <div class="p-6">
      <% if @my_tasks.any? %>
        <div class="space-y-2">
          <% @my_tasks.limit(5).each do |task| %>
            <%= link_to [@organization, task.project, task], class: "flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 transition-colors group dark:hover:bg-gray-700/50" do %>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-900 truncate group-hover:text-indigo-600 transition-colors dark:text-gray-100 dark:group-hover:text-indigo-400"><%= task.title %></p>
                <p class="text-xs text-gray-400 truncate mt-0.5"><%= task.project.name %></p>
              </div>
              <span class="<%= status_badge_class(task.status) %> ml-3 flex-shrink-0"><%= task.status.humanize %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-8">
          <div class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-500"><%= t("dashboard.no_tasks_assigned") %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between dark:border-gray-700 bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.okr_progress") %></h2>
      <% if @active_cycle %>
        <%= link_to [@organization, @active_cycle], class: "text-xs font-medium text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300 flex items-center gap-1" do %>
          <%= t("dashboard.view_cycle") %>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      <% end %>
    </div>
    <div class="p-6">
      <% if @active_cycle %>
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= @active_cycle.title %></p>
          <span class="text-2xl font-bold <%= @okr_progress >= 100 ? 'text-green-600 dark:text-green-400' : @okr_progress >= 75 ? 'text-blue-600 dark:text-blue-400' : @okr_progress >= 50 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' %>"><%= @okr_progress %>%</span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-3 mb-4 dark:bg-gray-700">
          <div class="h-3 rounded-full transition-all duration-700 ease-out <%= @okr_progress >= 100 ? 'bg-gradient-to-r from-green-500 to-emerald-400' : @okr_progress >= 75 ? 'bg-gradient-to-r from-blue-500 to-blue-400' : @okr_progress >= 50 ? 'bg-gradient-to-r from-yellow-500 to-yellow-400' : 'bg-gradient-to-r from-red-500 to-red-400' %>" style="width: <%= [@okr_progress, 100].min %>%"></div>
        </div>
        <div class="flex items-center gap-6 text-xs text-gray-500 dark:text-gray-400">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <%= t("dashboard.objectives_count", completed: @active_cycle.objectives_completed, total: @active_cycle.objectives.size) %>
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            <%= t("dashboard.krs_count", achieved: @active_cycle.krs_achieved, total: @active_cycle.kr_count) %>
          </span>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-6">
          <div class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-500"><%= t("dashboard.no_okr_cycle") %></p>
          <%= link_to new_organization_okr_cycle_path(@organization), class: "mt-2 text-xs font-medium text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300 flex items-center gap-1" do %>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <%= t("okrs.create_one") %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between dark:border-gray-700 bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.kpis_summary") %></h2>
      <%= link_to organization_kpis_path(@organization), class: "text-xs font-medium text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300 flex items-center gap-1" do %>
        <%= t("actions.view_all") %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="p-6">
      <% if @kpis.any? %>
        <div class="flex items-center justify-between mb-4">
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("dashboard.kpis_achieved", achieved: @kpi_achieved, total: @kpi_total) %></p>
          <div class="flex -space-x-1">
            <% @kpis.first(3).each do |kpi| %>
              <% progress = kpi.calculate_progress %>
              <span class="w-5 h-5 rounded-full text-[8px] font-bold flex items-center justify-center border-2 border-white dark:border-gray-800 <%= progress >= 100 ? 'bg-green-500 text-white' : progress >= 75 ? 'bg-blue-500 text-white' : progress >= 50 ? 'bg-yellow-500 text-white' : 'bg-red-500 text-white' %>"><%= kpi.name.first.upcase %></span>
            <% end %>
          </div>
        </div>
        <div class="space-y-3">
          <% @kpis.first(4).each do |kpi| %>
            <% progress = kpi.calculate_progress %>
            <div>
              <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-gray-700 font-medium truncate dark:text-gray-300"><%= kpi.name %></span>
                <span class="<%= progress >= 100 ? 'text-green-600 dark:text-green-400' : progress >= 75 ? 'text-blue-600 dark:text-blue-400' : progress >= 50 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' %> font-semibold ml-3"><%= kpi.current_value %>/<%= kpi.target_value %> <%= kpi.unit %></span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-1.5 dark:bg-gray-700">
                <div class="h-1.5 rounded-full transition-all duration-500 <%= progress >= 100 ? 'bg-gradient-to-r from-green-500 to-emerald-400' : progress >= 75 ? 'bg-gradient-to-r from-blue-500 to-blue-400' : progress >= 50 ? 'bg-gradient-to-r from-yellow-500 to-yellow-400' : 'bg-gradient-to-r from-red-500 to-red-400' %>" style="width: <%= [progress, 100].min %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-6">
          <div class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <p class="text-sm text-gray-400 dark:text-gray-500"><%= t("dashboard.no_kpis") %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% if @gantt_items.any? %>
  <div class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("gantt.timeline") %></h2>
    </div>
    <%= render "shared/gantt", items: @gantt_items, start_date: @gantt_start, end_date: @gantt_end, label_column: t("projects.title") %>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.recent_activity") %></h2>
    </div>
    <div class="divide-y divide-gray-100 dark:divide-gray-700">
      <% @recent_activity.each do |activity| %>
        <div class="px-6 py-3.5 flex items-center gap-3 hover:bg-gray-50 transition-colors dark:hover:bg-gray-700/50">
          <div class="w-8 h-8 bg-gradient-to-br from-indigo-100 to-purple-100 rounded-full flex items-center justify-center flex-shrink-0 dark:from-indigo-900/40 dark:to-purple-900/40">
            <span class="text-xs font-semibold text-indigo-600 dark:text-indigo-400"><%= activity.user.name.first.upcase %></span>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-sm text-gray-700 dark:text-gray-300"><strong><%= activity.user.name %></strong> <span class="text-gray-500 dark:text-gray-400"><%= activity.action %></span></p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5"><%= t("time.ago", time: time_ago_in_words(activity.created_at)) %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.projects_overview") %></h2>
    </div>
    <div class="divide-y divide-gray-100 dark:divide-gray-700">
      <% @projects.active.limit(6).each do |project| %>
        <%= link_to [@organization, project], class: "flex items-center justify-between px-6 py-3.5 hover:bg-gray-50 transition-colors group dark:hover:bg-gray-700/50" do %>
          <div class="flex items-center gap-3 min-w-0 flex-1">
            <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: <%= project.color || "#6366f1" %>"></span>
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate group-hover:text-indigo-600 transition-colors dark:text-gray-100 dark:group-hover:text-indigo-400"><%= project.name %></p>
              <p class="text-xs text-gray-400 dark:text-gray-500"><%= t("dashboard.tasks_count", count: project.tasks.count) %></p>
            </div>
          </div>
          <span class="<%= project_status_badge_class(project.status) %> ml-3 flex-shrink-0"><%= project.status.humanize %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
