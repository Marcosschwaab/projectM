<style>
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    width: 100%;
  }
  @media (max-width: 1024px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
  .dashboard-widget {
    transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .dashboard-widget {
    transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .dashboard-widget.dragging {
    opacity: 0.5;
    transform: scale(0.98) !important;
    z-index: 50;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .dashboard-widget.drag-over {
    border-color: #6366f1;
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.3);
  }
  .dashboard-resize-handle svg {
    transform: rotate(0deg);
  }
  .dashboard-resize-handle:hover svg {
    color: #6366f1;
  }
  .resizing, .dragging * {
    user-select: none !important;
  }
  .dashboard-grid-item {
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .dashboard-grid-item.widget-shifting {
    transform: translateY(var(--shift-amount, 0px));
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .dashboard-placeholder {
    border: 2px dashed #6366f1;
    border-radius: 12px;
    opacity: 0.5;
    animation: placeholderPulse 1.2s ease-in-out infinite;
  }
  @keyframes placeholderPulse {
    0%, 100% { opacity: 0.4; border-color: #6366f1; }
    50% { opacity: 0.8; border-color: #8b5cf6; box-shadow: 0 0 12px rgba(99,102,241,0.2); }
  }
  .widget-size-change {
    animation: widgetSizeAnim 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes widgetSizeAnim {
    0% { transform: scale(1); }
    30% { transform: scale(1.03); box-shadow: 0 8px 30px rgba(99,102,241,0.15); }
    70% { transform: scale(0.98); }
    100% { transform: scale(1); }
  }
</style>

<div data-controller="dashboard" class="max-w-full">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("dashboard.title") %></h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= l(Time.current, format: :dashboard) %></p>
    </div>
    <div class="flex items-center gap-2">
      <button type="button"
              data-action="click->dashboard#addWidget"
              class="px-3 py-2 text-sm font-medium bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors dark:bg-indigo-500 dark:hover:bg-indigo-600 flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        <%= t("dashboard.add_widget") %>
      </button>
    </div>
  </div>

  <div class="dashboard-grid" data-dashboard-target="grid">
    <% @widgets.each do |widget| %>
      <div class="dashboard-grid-item <%= widget.width == 3 ? 'lg:col-span-3' : widget.width == 2 ? 'lg:col-span-2' : 'lg:col-span-1' %> col-span-1">
        <%= render "dashboard/widget", widget: widget %>
      </div>
    <% end %>
  </div>
</div>
