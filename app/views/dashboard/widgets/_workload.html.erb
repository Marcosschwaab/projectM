<% data = @workload_data || [] %>
<% max_val = data.map { |w| w[:total] }.max || 1 %>

<div class="space-y-2">
  <% data.each do |entry| %>
    <% pct = (entry[:total].to_f / max_val * 100).round(1) %>
    <div>
      <div class="flex items-center justify-between text-xs mb-1">
        <span class="flex items-center gap-2">
          <span class="w-5 h-5 bg-indigo-100 dark:bg-indigo-900/30 rounded-full flex items-center justify-center text-[9px] font-semibold text-indigo-600 dark:text-indigo-400 flex-shrink-0"><%= entry[:name].first.upcase %></span>
          <span class="text-gray-600 dark:text-gray-400"><%= entry[:name] %></span>
        </span>
        <span class="font-semibold text-gray-900 dark:text-gray-100 ml-2"><%= entry[:total] %> (<%= entry[:done] %> done)</span>
      </div>
      <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
        <div class="h-full rounded-full bg-gradient-to-r from-blue-500 to-cyan-400 transition-all duration-500" style="width: <%= pct %>%"></div>
      </div>
    </div>
  <% end %>
  <% if data.empty? %>
    <p class="text-sm text-gray-400 text-center py-4 dark:text-gray-500"><%= t("dashboard.no_tasks_assigned") %></p>
  <% end %>
</div>
