<% limit = widget.settings["limit"] || 5 %>
<% due_this_week = @tasks.where(due_date: Date.today..7.days.from_now).where.not(status: :done) %>
<% if due_this_week.any? %>
  <div class="space-y-2">
    <% due_this_week.limit(limit).each do |task| %>
      <%= link_to [@organization, task.project, task], class: "flex items-center justify-between p-2.5 rounded-lg hover:bg-gray-50 transition-colors group dark:hover:bg-gray-700/50" do %>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium text-gray-900 truncate group-hover:text-indigo-600 transition-colors dark:text-gray-100 dark:group-hover:text-indigo-400"><%= task.title %></p>
          <p class="text-xs text-gray-400 truncate mt-0.5"><%= task.project.name %></p>
        </div>
        <span class="text-xs font-semibold ml-3 px-2 py-1 rounded-full <%= task.due_date == Date.today ? "bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-400" : "bg-yellow-50 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400" %>">
          <%= l(task.due_date, format: :short) %>
        </span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-6">
    <div class="w-10 h-10 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mb-2">
      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    </div>
    <p class="text-sm text-gray-400 dark:text-gray-500"><%= t("calendar.no_deadlines") %></p>
  </div>
<% end %>
