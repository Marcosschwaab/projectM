<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
  <div class="rounded-xl border border-gray-200 p-3 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:border-gray-700 border-t-2 border-t-indigo-500 bg-white dark:bg-gray-800/50">
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.active_projects") %></span>
      <svg class="w-3.5 h-3.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
    </div>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @active_projects_count %></p>
  </div>
  <div class="rounded-xl border border-gray-200 p-3 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:border-gray-700 border-t-2 border-t-green-500 bg-white dark:bg-gray-800/50">
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.done") %></span>
      <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= @completed_projects_count %></p>
  </div>
  <div class="rounded-xl border border-gray-200 p-3 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:border-gray-700 border-t-2 border-t-blue-500 bg-white dark:bg-gray-800/50">
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.open_tasks") %></span>
      <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
    </div>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @open_tasks_count %></p>
  </div>
  <div class="rounded-xl border border-gray-200 p-3 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:border-gray-700 border-t-2 border-t-red-500 bg-white dark:bg-gray-800/50">
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.overdue") %></span>
      <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <p class="text-2xl font-bold text-red-600 dark:text-red-400"><%= @overdue_tasks.count %></p>
  </div>
  <div class="rounded-xl border border-gray-200 p-3 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:border-gray-700 border-t-2 border-t-purple-500 bg-white dark:bg-gray-800/50">
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.my_tasks") %></span>
      <svg class="w-3.5 h-3.5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    </div>
    <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400"><%= @my_tasks.count %></p>
  </div>
  <div class="rounded-xl border border-gray-200 p-3 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 dark:border-gray-700 border-t-2 border-t-gray-400 bg-white dark:bg-gray-800/50">
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("dashboard.team") %></span>
      <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    </div>
    <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @members_count %></p>
  </div>
</div>
