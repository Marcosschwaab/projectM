<div class="dashboard-widget relative bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700 transition-all duration-200 hover:shadow-md group"
     data-widget-id="<%= widget.id %>"
     data-widget-type="<%= widget.widget_type %>"
     data-widget-width="<%= widget.width %>"
     data-dashboard-target="widget">
  <div class="px-5 py-3.5 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between bg-gradient-to-r from-transparent to-gray-50/50 dark:to-gray-800">
    <div class="flex items-center gap-2 min-w-0">
      <span class="cursor-grab text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 touch-none" data-action="mousedown->dashboard#startDrag" data-dashboard-target="dragHandle">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg>
      </span>
      <h3 class="text-sm font-semibold text-gray-900 truncate dark:text-gray-100"><%= t("dashboard.widgets.#{widget.widget_type}") %></h3>
    </div>
    <div class="flex items-center gap-0.5 flex-shrink-0">
      <button type="button"
              class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors dark:hover:text-gray-300 dark:hover:bg-gray-700"
              data-action="click->dashboard#toggleSettings"
              title="<%= t("actions.settings") %>">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </button>
      <button type="button"
              class="p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors dark:hover:text-red-400 dark:hover:bg-red-900/20"
              data-action="click->dashboard#removeWidget"
              title="<%= t("actions.remove") %>">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
  <div class="p-5">
    <%= render "dashboard/widgets/#{widget.widget_type}", widget: widget %>
  </div>
  <div class="dashboard-resize-handle absolute bottom-0 right-0 w-5 h-5 cursor-se-resize opacity-0 group-hover:opacity-100 transition-opacity z-10"
       data-action="mousedown->dashboard#startResize">
    <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 20L14 20M20 20L20 14M20 20L4 4"/></svg>
  </div>
</div>
