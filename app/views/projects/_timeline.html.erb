<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
  <h2 class="text-lg font-semibold text-gray-900 mb-4 dark:text-gray-100"><%= t("activity.timeline") %></h2>

  <% if activities.any? %>
    <div class="flow-root">
      <ul class="-mb-4">
        <% activities.each do |activity| %>
          <li class="relative pb-4">
            <% unless activity == activities.last %>
              <div class="absolute left-3 top-5 bottom-0 w-px bg-gray-200 dark:bg-gray-700"></div>
            <% end %>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0 mt-0.5 dark:bg-indigo-900/30">
                <span class="text-[10px] font-medium text-indigo-600 dark:text-indigo-400"><%= activity.user.name.first.upcase %></span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-gray-900 dark:text-gray-100">
                  <span class="font-medium"><%= activity.user.name %></span>
                  <span class="text-gray-500 dark:text-gray-400"><%= activity.action %></span>
                </p>
                <p class="text-xs text-gray-400 mt-0.5 dark:text-gray-500"><%= l(activity.created_at, format: :long) %></p>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="text-center py-8">
      <svg class="mx-auto w-12 h-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="mt-3 text-sm text-gray-500 dark:text-gray-400"><%= t("activity.no_activity") %></p>
    </div>
  <% end %>
</div>
