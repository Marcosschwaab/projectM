<h1>New project</h1>

<%= form_with(model: [@organization, @project]) do |f| %>
  <% if @project.errors.any? %>
    <div>
      <h2><%= pluralize(@project.errors.count, "error") %> prohibited this project from being saved:</h2>
      <ul>
        <% @project.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :priority %>
    <%= f.select :priority, Project.priorities.keys.map { |k| [k.humanize, k] } %>
  </div>

  <div>
    <%= f.label :assignee_id %>
    <%= f.collection_select :assignee_id, @organization.members, :id, :name, include_blank: "Unassigned" %>
  </div>

  <div>
    <%= f.label :start_date %>
    <%= f.date_field :start_date %>
  </div>

  <div>
    <%= f.label :end_date %>
    <%= f.date_field :end_date %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>

<%= link_to "Back", organization_projects_path(@organization) %>
