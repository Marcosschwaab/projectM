<div class="mb-6">
  <%= link_to organization_project_path(@organization, @project), class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_project") %>
  <% end %>
</div>

<div class="max-w-2xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 dark:bg-gray-800 dark:border-gray-700">
    <h1 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("projects.edit") %></h1>

    <%= render "form", cancel_path: organization_project_path(@organization, @project) %>
  </div>
</div>
