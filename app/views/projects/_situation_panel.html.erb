<% metrics = project.evm_metrics %>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
  <h2 class="text-lg font-semibold text-gray-900 mb-4 dark:text-gray-100"><%= t("projects.situation.title") %></h2>

  <div class="grid grid-cols-2 gap-4">
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.situation.percent_complete") %></p>
      <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= metrics[:percent_complete] %>%</p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.situation.percent_ideal") %></p>
      <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= metrics[:percent_ideal] %>%</p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.situation.idc") %></p>
      <p class="text-xl font-bold <%= metrics[:idc] >= 1 ? 'text-green-600 dark:text-green-400' : metrics[:idc] >= 0.8 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' %>"><%= metrics[:idc] %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.situation.idp") %></p>
      <p class="text-xl font-bold <%= metrics[:idp] >= 1 ? 'text-green-600 dark:text-green-400' : metrics[:idp] >= 0.8 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' %>"><%= metrics[:idp] %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50 col-span-2">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.situation.task_rate") %></p>
      <div class="w-full bg-gray-200 rounded-full h-2.5 dark:bg-gray-600">
        <div class="h-2.5 rounded-full <%= metrics[:task_rate] >= 80 ? 'bg-green-500' : metrics[:task_rate] >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= metrics[:task_rate] %>%"></div>
      </div>
      <p class="text-sm font-medium text-gray-900 dark:text-gray-100 mt-1"><%= metrics[:task_rate] %>%</p>
    </div>
  </div>
</div>
