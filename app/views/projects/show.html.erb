<%= render "shared/project_nav" %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 dark:bg-gray-800 dark:border-gray-700">
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3">
      <span class="w-4 h-4 rounded-full flex-shrink-0" style="background-color: <%= @project.color || "#6366f1" %>"></span>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @project.name %></h1>
      <% if @project.category.present? %>
        <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300"><%= Project::CATEGORIES.include?(@project.category) ? t("projects.categories.#{@project.category}") : @project.category.humanize %></span>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <span class="<%= project_status_badge_class(@project.status) %>"><%= @project.status&.humanize %></span>
      <span class="<%= priority_class(@project.priority) %>"><%= @project.priority&.humanize %></span>
      <%= link_to edit_organization_project_path(@organization, @project), class: "flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition-colors dark:text-gray-400 dark:hover:bg-gray-700" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        <%= t("actions.edit") %>
      <% end %>
    </div>
  </div>

  <p class="text-gray-600 mb-6 dark:text-gray-400"><%= @project.description %></p>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.assignee") %></p>
      <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @project.assignee&.name || t("projects.unassigned") %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.progress") %></p>
      <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @project.progress %>%</p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.start_date") %></p>
      <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @project.start_date || "-" %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.end_date") %></p>
      <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @project.end_date || "-" %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.team.sponsor") %></p>
      <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @project.sponsor&.name || t("projects.unassigned") %></p>
    </div>
    <div class="p-3 bg-gray-50 rounded-lg dark:bg-gray-700/50">
      <p class="text-xs text-gray-500 mb-1 dark:text-gray-400"><%= t("projects.team.manager") %></p>
      <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @project.manager&.name || t("projects.unassigned") %></p>
    </div>
  </div>

  <% if @project.project_members.includes(:user).any? %>
    <div class="space-y-2 mb-4">
      <% managers = @project.project_members.where(role: :manager).includes(:user) %>
      <% if managers.any? %>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs text-gray-500 dark:text-gray-400 self-center"><%= t("projects.team.project_managers") %>:</span>
          <% managers.each do |pm| %>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">
              <%= pm.user.name %>
            </span>
          <% end %>
        </div>
      <% end %>
      <% members = @project.project_members.where(role: :member).includes(:user) %>
      <% if members.any? %>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs text-gray-500 dark:text-gray-400 self-center"><%= t("projects.team.members") %>:</span>
          <% members.each do |pm| %>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300">
              <%= pm.user.name %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @project.approval_role_list.any? %>
    <div class="p-3 bg-amber-50 rounded-lg border border-amber-200 dark:bg-amber-900/20 dark:border-amber-800">
      <p class="text-xs font-medium text-amber-800 dark:text-amber-300"><%= t("projects.approval.title") %></p>
      <p class="text-xs text-amber-700 dark:text-amber-400 mt-1">
        <%= @project.approval_role_list.map { |r| t("projects.approval.display_roles.#{r}") }.join(", ") %>
      </p>
    </div>
  <% end %>
</div>

<div class="mb-6">
  <%= render "projects/financial", project: @project %>
</div>



<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 dark:bg-gray-800 dark:border-gray-700">
  <h2 class="text-lg font-semibold text-gray-900 mb-4 dark:text-gray-100"><%= t("tasks.title") %></h2>
  <% if @project.tasks.any? %>
    <div class="space-y-2">
      <% @project.tasks.by_status.each do |task| %>
        <%= link_to [@organization, @project, task], class: "block p-3 rounded-lg border border-gray-100 hover:border-gray-200 hover:bg-gray-50 transition-colors dark:border-gray-700 dark:hover:border-gray-600 dark:hover:bg-gray-700/50" do %>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= task.title %></span>
            <span class="text-xs <%= task.status == "done" ? "text-green-600 bg-green-50 dark:text-green-400 dark:bg-green-900/30" : "text-gray-500 bg-gray-100 dark:text-gray-400 dark:bg-gray-700" %> px-2 py-0.5 rounded-full"><%= task.status&.humanize %></span>
          </div>
          <div class="flex items-center gap-3 mt-1 text-xs text-gray-400">
            <span><%= task.assignee&.name || t("projects.unassigned") %></span>
            <span><%= task.due_date %></span>
            <span class="<%= priority_class(task.priority) %>"><%= task.priority&.humanize %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("tasks.no_tasks") %></p>
  <% end %>
</div>

<% if @gantt_items.any? %>
  <div class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("gantt.title") %></h2>
    </div>
    <%= render "shared/gantt", items: @gantt_items, start_date: @gantt_start, end_date: @gantt_end, label_column: t("tasks.title") %>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 mb-4 dark:text-gray-100"><%= t("projects.okr_alignment") %></h2>
    <% if @project.objectives.any? %>
      <div class="space-y-3">
        <% @project.objectives.includes(:okr_cycle, :key_results).each do |objective| %>
          <div class="p-3 border border-gray-100 rounded-lg dark:border-gray-700">
            <div class="flex items-center justify-between mb-1">
              <%= link_to [@organization, objective.okr_cycle], class: "text-sm font-medium text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
                <%= objective.title %>
              <% end %>
              <span class="text-xs text-gray-400"><%= objective.okr_cycle.title %></span>
            </div>
            <% obj_progress = objective.calculate_progress %>
            <div class="w-full bg-gray-100 rounded-full h-1.5 mt-2 dark:bg-gray-700">
              <div class="h-1.5 rounded-full <%= obj_progress >= 100 ? 'bg-green-500' : obj_progress >= 75 ? 'bg-blue-500' : obj_progress >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= [obj_progress, 100].min %>%"></div>
            </div>
            <p class="text-xs text-gray-400 mt-1"><%= t("okrs.key_results", count: objective.key_results.size) %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("projects.no_objectives") %></p>
      <p class="text-xs text-gray-400 mt-1"><%= t("projects.link_objectives_hint") %></p>
    <% end %>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 mb-4 dark:text-gray-100"><%= t("projects.project_kpis") %></h2>
    <% project_kpis = @project.kpis %>
    <% if project_kpis.any? %>
      <div class="space-y-3">
        <% project_kpis.each do |kpi| %>
          <% progress = kpi.calculate_progress %>
          <div>
            <div class="flex items-center justify-between text-sm mb-1">
              <span class="font-medium text-gray-900 dark:text-gray-100"><%= kpi.name %></span>
              <span class="<%= progress >= 100 ? 'text-green-600 dark:text-green-400' : progress >= 75 ? 'text-blue-600 dark:text-blue-400' : progress >= 50 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' %> font-medium"><%= kpi.current_value %>/<%= kpi.target_value %> <%= kpi.unit %></span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5 dark:bg-gray-700">
              <div class="h-1.5 rounded-full <%= progress >= 100 ? 'bg-green-500' : progress >= 75 ? 'bg-blue-500' : progress >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= [progress, 100].min %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("projects.no_kpis") %></p>
      <p class="text-xs text-gray-400 mt-1"><%= link_to t("projects.create_kpis_link"), new_organization_kpi_path(@organization, kpi: { project_id: @project.id }), class: "text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %> <%= t("projects.create_kpis_hint") %></p>
    <% end %>
  </div>
</div>

<div class="mt-6">
  <%= render "projects/situation_panel", project: @project %>
</div>

<% if @project.risks.any? %>
  <div class="mt-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("risks.title") %></h2>
        <%= link_to organization_project_risks_path(@organization, @project), class: "text-sm font-medium text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
          <%= t("actions.view_all") %>
        <% end %>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <% @project.risks.by_severity.limit(8).each do |risk| %>
          <%= link_to [@organization, @project, risk], class: "block p-3 rounded-lg border border-gray-100 hover:border-gray-200 hover:bg-gray-50 transition-colors dark:border-gray-700 dark:hover:border-gray-600 dark:hover:bg-gray-700/50" do %>
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate"><%= risk.name %></span>
              <span class="text-xs font-semibold px-1.5 py-0.5 rounded <%= risk_severity_class(risk.severity_label) %>"><%= risk.severity %></span>
            </div>
            <span class="<%= risk_status_badge_class(risk.status) %> px-1.5 py-0.5 rounded-full text-[10px] font-medium"><%= t("risks.statuses.#{risk.status}") %></span>
          <% end %>
        <% end %>
      </div>
      <% if @project.risks.count > 8 %>
        <div class="mt-3 text-center">
          <%= link_to organization_project_risks_path(@organization, @project), class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
            <%= t("actions.view_all") %> (<%= @project.risks.count %>)
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="mt-6">
  <%= render "timeline", activities: @activity_logs %>
</div>
