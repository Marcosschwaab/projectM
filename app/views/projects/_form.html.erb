<%= form_with(model: [@organization, @project], data: { turbo: false }) do |f| %>
  <% if @project.errors.any? %>
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm dark:bg-red-900/30 dark:border-red-800 dark:text-red-400">
      <h2 class="font-semibold mb-1"><%= pluralize(@project.errors.count, t("errors.error", count: @project.errors.count)) %> <%= t("errors.prohibited", model: t("projects.title").downcase) %></h2>
      <ul class="list-disc pl-4 space-y-1">
        <% @project.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div data-controller="project-form-tabs">
    <div class="border-b border-gray-200 dark:border-gray-700 mb-6" role="tablist">
      <button type="button" role="tab"
              data-project-form-tabs-target="tab"
              data-action="project-form-tabs#switch"
              data-index="0"
              class="inline-flex items-center px-4 py-2.5 text-sm font-medium border-b-2 border-indigo-600 text-indigo-600 dark:border-indigo-400 dark:text-indigo-400 transition-colors whitespace-nowrap"
              aria-selected="true">
        <%= t("projects.form.tabs.general") %><span class="text-red-500 ml-0.5">*</span>
      </button>
      <button type="button" role="tab"
              data-project-form-tabs-target="tab"
              data-action="project-form-tabs#switch"
              data-index="1"
              class="inline-flex items-center px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors whitespace-nowrap"
              aria-selected="false">
        <%= t("projects.form.tabs.responsibles") %><span class="text-red-500 ml-0.5">*</span>
      </button>
      <button type="button" role="tab"
              data-project-form-tabs-target="tab"
              data-action="project-form-tabs#switch"
              data-index="2"
              class="inline-flex items-center px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors whitespace-nowrap"
              aria-selected="false">
        <%= t("projects.financial.title") %>
      </button>
    </div>

    <div data-project-form-tabs-target="panel" role="tabpanel" class="space-y-4">
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div>
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :category, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <div class="relative" data-controller="combobox"
               data-combobox-options-value="<%= Project::CATEGORIES.map { |c| { value: c, label: t("projects.categories.#{c}") } }.to_json %>">
            <%= f.text_field :category,
                    data: { combobox_target: "input", action: "input->combobox#filter focus->combobox#filter keydown->combobox#keydown" },
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
            <div data-combobox-target="dropdown"
                 class="hidden absolute z-10 mt-1 w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg max-h-48 overflow-y-auto"></div>
          </div>
        </div>

        <div>
          <%= f.label :priority, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.select :priority, Project.priorities.keys.map { |k| [k.humanize, k] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.date_field :start_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div>
          <%= f.label :end_date, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.date_field :end_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
      </div>

      <% if @organization.custom_fields.any? %>
        <%= render "custom_fields/form_fields", fields: @organization.custom_fields.order(:name), task: @project %>
      <% end %>
    </div>

    <div data-project-form-tabs-target="panel" role="tabpanel" class="hidden space-y-4">
      <div data-controller="searchable-select" data-searchable-select-placeholder-value="<%= t("tasks.search_members") %>">
        <%= f.label :sponsor_id, t("projects.team.sponsor"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.collection_select :sponsor_id, @organization.members, :id, :name, { include_blank: t("projects.unassigned") }, data: { searchable_select_target: "select" }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div data-controller="searchable-select" data-searchable-select-placeholder-value="<%= t("tasks.search_members") %>">
        <%= f.label :manager_id, t("projects.team.manager"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.collection_select :manager_id, @organization.members, :id, :name, { include_blank: t("projects.unassigned") }, data: { searchable_select_target: "select" }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div data-controller="searchable-select" data-searchable-select-placeholder-value="<%= t("tasks.search_members") %>">
        <%= f.label :assignee_id, t("projects.team.responsible"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.collection_select :assignee_id, @organization.members, :id, :name, { include_blank: t("projects.unassigned") }, data: { searchable_select_target: "select" }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div>
        <%= label_tag :member_search, t("projects.team.members"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <div data-controller="member-search"
             data-member-search-members-value="<%= @organization.members.select(:id, :name).to_json %>"
             data-member-search-selected-value="<%= @project.members.ids.to_json %>">
          <div class="relative">
            <input type="text"
                   data-member-search-target="input"
                   data-action="input->member-search#filter focus->member-search#showResults keydown->member-search#keydown"
                   placeholder="<%= t("tasks.search_members") %>"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200 placeholder-gray-400 dark:placeholder-gray-500">
            <div data-member-search-target="dropdown"
                 class="hidden absolute z-10 mt-1 w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg max-h-48 overflow-y-auto"></div>
          </div>
          <div data-member-search-target="selected" class="flex flex-wrap gap-1.5 mt-2"></div>
          <div data-member-search-target="hiddenFields"></div>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-100 dark:border-gray-700">
        <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"><%= t("projects.approval.title") %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3"><%= t("projects.approval.hint") %></p>
        <div class="space-y-2">
          <% Project::APPROVAL_ROLES.each do |role| %>
            <label class="flex items-center gap-2">
              <%= check_box_tag "project[approval_roles][]", role, @project.approval_roles&.include?(role), id: "project_approval_roles_#{role}", class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700" %>
              <span class="text-sm text-gray-700 dark:text-gray-300"><%= t("projects.approval.roles.#{role}") %></span>
            </label>
          <% end %>
          <label class="flex items-center gap-2 pt-1 border-t border-gray-100 dark:border-gray-700">
            <%= f.check_box :approval_all_team, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700" %>
            <span class="text-sm text-gray-700 dark:text-gray-300"><%= t("projects.approval.all_team") %></span>
          </label>
        </div>
      </div>
    </div>

    <div data-project-form-tabs-target="panel" role="tabpanel" class="hidden space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :proposal_investment_estimated, t("projects.financial.proposal_investment_estimated"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :proposal_investment_estimated, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :project_investment_estimated, t("projects.financial.project_investment_estimated"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :project_investment_estimated, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :budget_estimated, t("projects.financial.budget_estimated"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :budget_estimated, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :budget_actual, t("projects.financial.budget_actual"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :budget_actual, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :return_estimated, t("projects.financial.return_estimated"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :return_estimated, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :return_actual, t("projects.financial.return_actual"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :return_actual, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-4 pt-6 mt-6 border-t border-gray-200 dark:border-gray-700">
      <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
      <%= link_to t("actions.cancel"), cancel_path, class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700" %>
    </div>
  </div>
<% end %>
