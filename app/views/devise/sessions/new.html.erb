<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 dark:bg-gray-800 dark:border-gray-700">
  <h2 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("devise.sessions.title") %></h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), data: { turbo: false }) do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700" %>
          <%= f.label :remember_me, t("devise.sessions.remember_me"), class: "text-sm text-gray-600 dark:text-gray-400" %>
        </div>
      <% end %>

      <div>
        <%= f.submit t("devise.sessions.sign_in"), class: "w-full px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
      </div>
    </div>
  <% end %>

  <div class="mt-6 text-center space-y-2">
    <%= render "devise/shared/links" %>
  </div>
</div>

<div class="mt-4 text-center">
  <p class="text-xs text-gray-400 dark:text-gray-500"><%= t("devise.sessions.demo_hint") %></p>
</div>
