<% model_name = task.model_name.param_key %>
<% fields.each do |field| %>
  <% value_obj = task.custom_field_values.find { |v| v.custom_field_id == field.id } %>
  <% value = value_obj&.value %>
  <% field_name = "#{model_name}[custom_field_values_attributes][#{field.id}][value]" %>
  <% field_id = "#{model_name}_custom_field_values_#{field.id}" %>
  <% required = field.required ? { required: true } : {} %>

  <div>
    <%= label_tag field_id, field.name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
    <% if field.required %>
      <span class="text-red-500">*</span>
    <% end %>

    <% case field.field_type
       when "text" %>
      <%= text_field_tag field_name, value, { id: field_id, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" }.merge(required) %>
    <% when "number" %>
      <%= number_field_tag field_name, value, { id: field_id, step: "any", class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" }.merge(required) %>
    <% when "date" %>
      <%= date_field_tag field_name, value, { id: field_id, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" }.merge(required) %>
    <% when "select" %>
      <%= select_tag field_name, options_for_select(field.options, value), { include_blank: true, id: field_id, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" }.merge(required) %>
    <% end %>
    <% if value_obj&.persisted? %>
      <%= hidden_field_tag "#{model_name}[custom_field_values_attributes][#{field.id}][id]", value_obj.id %>
    <% end %>
    <%= hidden_field_tag "#{model_name}[custom_field_values_attributes][#{field.id}][custom_field_id]", field.id %>
  </div>
<% end %>
