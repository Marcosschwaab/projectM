<div class="mb-6">
  <%= link_to organization_custom_fields_path(@organization), class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_custom_fields") %>
  <% end %>
</div>

<div class="max-w-lg">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 dark:bg-gray-800 dark:border-gray-700">
    <h1 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("custom_fields.edit") %></h1>

    <%= form_with(model: [@organization, @custom_field]) do |f| %>
      <% if @custom_field.errors.any? %>
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm dark:bg-red-900/30 dark:border-red-800 dark:text-red-400">
          <h2 class="font-semibold mb-1"><%= pluralize(@custom_field.errors.count, t("errors.error", count: @custom_field.errors.count)) %> <%= t("errors.prohibited", model: t("custom_fields.singular").downcase) %></h2>
          <ul class="list-disc pl-4 space-y-1">
            <% @custom_field.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div>
          <%= f.label :field_type, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.select :field_type, CustomField::FIELD_TYPES.map { |t| [t("custom_fields.types.#{t}"), t] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div>
          <%= f.label :options, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <span class="text-xs text-gray-400 dark:text-gray-500"><%= t("custom_fields.options_hint") %></span>
          <%= f.text_field :options, value: @custom_field.options&.join(", "), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div class="flex items-center gap-2">
          <%= f.check_box :required, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 dark:border-gray-600 dark:bg-gray-700" %>
          <%= f.label :required, class: "text-sm text-gray-700 dark:text-gray-300" %>
        </div>

        <div class="flex items-center gap-4 pt-2">
          <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer dark:bg-indigo-500 dark:hover:bg-indigo-600" %>
          <%= link_to t("actions.cancel"), organization_custom_fields_path(@organization), class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
