<aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
  <div class="p-4 border-b border-gray-200">
    <h1 class="text-lg font-bold text-indigo-600">ProjectM</h1>
  </div>

  <nav class="flex-1 p-4 space-y-1">
    <%= link_to dashboard_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium #{current_page?(dashboard_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50'}" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      Dashboard
    <% end %>

    <% if current_user.organizations.any? %>
      <% org = current_user.organizations.first %>
      <%= link_to organization_projects_path(org), class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium #{request.path.include?('/projects') ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
        Projects
      <% end %>

      <%= link_to organization_okr_cycles_path(org), class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium #{request.path.include?('/okr_cycles') ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        OKRs
      <% end %>

      <%= link_to report_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium #{current_page?(report_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Reports
      <% end %>

      <%= link_to organizations_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium #{current_page?(organizations_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-600 hover:bg-gray-50'}" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Organizations
      <% end %>
    <% end %>
  </nav>

  <div class="p-4 border-t border-gray-200">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
        <span class="text-sm font-medium text-indigo-600"><%= current_user.name.first.upcase %></span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-900 truncate"><%= current_user.name %></p>
        <p class="text-xs text-gray-500 truncate"><%= current_user.email %></p>
      </div>
    </div>
    <div class="mt-3 space-y-1">
      <%= link_to edit_user_registration_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 rounded-lg" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Settings
      <% end %>
      <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-2 px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg w-full text-left" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Sign out
      <% end %>
    </div>
  </div>
</aside>
