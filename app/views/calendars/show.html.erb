<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("calendar.title") %></h1>
    <p class="text-sm text-gray-500 dark:text-gray-400"><%= @organization.name %></p>
  </div>
</div>

<% padding_days = @start_date.wday %>
<% total_days = @end_date.day %>
<% remaining = (7 - (padding_days + total_days) % 7) % 7 %>
<% total_cells = padding_days + total_days + remaining %>
<% num_rows = total_cells / 7 %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 dark:bg-gray-800 dark:border-gray-700 overflow-hidden">
  <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <div class="flex items-center gap-3">
      <%= link_to organization_calendar_path(@organization, year: @start_date.prev_month.year, month: @start_date.prev_month.month), class: "p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors dark:text-gray-500 dark:hover:text-gray-300 dark:hover:bg-gray-700" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <% end %>
      <h2 class="text-lg font-semibold text-gray-900 min-w-[160px] text-center dark:text-gray-100">
        <%= l(@start_date, format: :month_year) %>
      </h2>
      <%= link_to organization_calendar_path(@organization, year: @start_date.next_month.year, month: @start_date.next_month.month), class: "p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors dark:text-gray-500 dark:hover:text-gray-300 dark:hover:bg-gray-700" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
      <%= link_to organization_calendar_path(@organization), class: "ml-2 px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors dark:bg-indigo-500 dark:hover:bg-indigo-600" do %>
        <%= t("calendar.today") %>
      <% end %>
    </div>
    <div class="text-sm text-gray-500 dark:text-gray-400">
      <%= t("calendar.tasks_with_deadlines_count", count: @tasks.size) %>
    </div>
  </div>

  <div class="grid grid-cols-7 border-b border-gray-200 dark:border-gray-700">
    <% t("date.abbr_day_names").each do |day| %>
      <div class="px-3 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center border-r border-gray-200 last:border-r-0 dark:text-gray-400 dark:border-gray-700">
        <%= day %>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-7" style="grid-template-rows: repeat(<%= num_rows %>, 1fr); height: <%= num_rows * 130 %>px">
    <% padding_days.times do %>
      <div class="border-r border-b border-gray-100 bg-gray-50/30 p-2 overflow-hidden dark:border-gray-700 dark:bg-gray-800/30"></div>
    <% end %>

    <% (@start_date..@end_date).each do |date| %>
      <% tasks_today = @tasks_by_date[date] || [] %>
      <% is_today = date == @today %>
      <% is_weekend = date.saturday? || date.sunday? %>
      <% has_tasks = tasks_today.any? %>

      <div class="flex flex-col border-r border-b border-gray-100 p-2 overflow-hidden dark:border-gray-700
                  <%= is_today ? 'bg-indigo-50/40 dark:bg-indigo-900/20' : '' %>
                  <%= is_weekend && !is_today ? 'bg-gray-50/40 dark:bg-gray-800/30' : '' %>">
        <div class="flex items-center justify-between mb-1.5">
          <span class="inline-flex items-center justify-center text-xs font-medium leading-none
                       <%= is_today ? 'w-6 h-6 bg-indigo-600 text-white rounded-full font-bold dark:bg-indigo-500' : has_tasks ? 'text-gray-900 dark:text-gray-100' : 'text-gray-400 dark:text-gray-500' %>">
            <%= date.day %>
          </span>
          <% if has_tasks %>
            <span class="text-[10px] font-medium text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-700 px-1.5 py-0.5 rounded-full leading-none flex-shrink-0"><%= tasks_today.size %></span>
          <% end %>
        </div>

        <div class="flex-1 space-y-1 overflow-y-auto min-h-0">
          <% tasks_today.first(4).each do |task| %>
            <%= link_to [task.project.organization, task.project, task],
                        class: "flex items-center gap-1.5 px-1.5 py-1 rounded-md text-[11px] font-medium leading-tight text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700/60 transition-colors",
                        data: { action: "slideover#open", modal_title: task.title, url: modal_organization_project_task_path(task.project.organization, task.project, task) } do %>
              <span class="w-2 h-2 rounded-full flex-shrink-0 <%= task.status == 'done' ? 'bg-emerald-500' : task.status == 'in_review' ? 'bg-violet-500' : task.status == 'in_progress' ? 'bg-blue-500' : 'bg-gray-400' %>"></span>
              <span class="truncate"><%= task.title %></span>
            <% end %>
          <% end %>
          <% if tasks_today.size > 4 %>
            <span class="block text-[11px] text-indigo-600 font-medium px-1.5 dark:text-indigo-400">
              +<%= tasks_today.size - 4 %> more
            </span>
          <% end %>
        </div>
      </div>
    <% end %>

    <% remaining.times do %>
      <div class="border-r border-b border-gray-100 bg-gray-50/30 p-2 overflow-hidden dark:border-gray-700 dark:bg-gray-800/30"></div>
    <% end %>
  </div>
</div>
