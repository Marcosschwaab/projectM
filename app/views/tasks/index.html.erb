<h1>Tasks</h1>

<%= link_to "New task", new_organization_project_task_path(@organization, @project) %>

<ul>
  <% @tasks.each do |task| %>
    <li>
      <%= link_to task.title, [@organization, @project, task] %>
      <span><%= task.status %></span>
      <span><%= task.priority %></span>
      <span><%= task.assignee&.name || "Unassigned" %></span>
    </li>
  <% end %>
</ul>
