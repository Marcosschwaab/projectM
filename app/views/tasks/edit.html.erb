<div class="mb-6">
  <%= link_to [@organization, @project, @task], class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_task") %>
  <% end %>
</div>

<div class="max-w-2xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 dark:bg-gray-800 dark:border-gray-700">
    <h1 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("tasks.edit") %></h1>

    <%= form_with(model: [@organization, @project, @task], data: { turbo: false }) do |f| %>
      <% if @task.errors.any? %>
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm dark:bg-red-900/30 dark:border-red-800 dark:text-red-400">
          <h2 class="font-semibold mb-1"><%= pluralize(@task.errors.count, t("errors.error", count: @task.errors.count)) %> <%= t("errors.prohibited", model: t("tasks.title").downcase) %></h2>
          <ul class="list-disc pl-4 space-y-1">
            <% @task.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div>
          <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
            <%= f.select :status, Task.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
          </div>

          <div>
            <%= f.label :priority, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
            <%= f.select :priority, Task.priorities.keys.map { |k| [k.humanize, k] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
          </div>

          <div>
            <%= f.label :assignee_id, t("tasks.fields.assignee"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
            <%= f.collection_select :assignee_id, @organization.members, :id, :name, { include_blank: t("projects.unassigned") }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
          </div>

          <div>
            <%= f.label :due_date, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
            <%= f.date_field :due_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
          </div>
        </div>

        <div>
          <%= f.label :dependency_ids, t("tasks.dependencies"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.collection_select :dependency_ids, @project.tasks.where.not(id: @task.id).order(:title), :id, :title, {}, { multiple: true, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" } %>
        </div>

        <div>
          <%= f.label :files, t("attachments.files"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.file_field :files, multiple: true, class: "w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 dark:file:bg-indigo-900/30 dark:file:text-indigo-400 dark:hover:file:bg-indigo-900/50 dark:text-gray-400" %>
          <%= render "shared/attachments", attachable: @task %>
        </div>

        <div>
          <%= f.label :tag_ids, t("tags.title"), class: "block text-sm font-medium text-gray-700 mb-2 dark:text-gray-300" %>
          <div class="flex flex-wrap gap-2">
            <%= f.collection_check_boxes :tag_ids, @organization.tags.order(:name), :id, :name do |b| %>
              <label class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 text-sm cursor-pointer hover:bg-gray-50 has-[:checked]:border-indigo-400 has-[:checked]:bg-indigo-50 dark:border-gray-600 dark:hover:bg-gray-700/50 dark:has-[:checked]:border-indigo-500 dark:has-[:checked]:bg-indigo-900/20">
                <%= b.check_box class: "accent-indigo-600 dark:accent-indigo-400" %>
                <%= b.text %>
              </label>
            <% end %>
          </div>
        </div>

        <div class="flex items-center gap-4 pt-2">
          <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer dark:bg-indigo-500 dark:hover:bg-indigo-600" %>
          <%= link_to t("actions.cancel"), [@organization, @project, @task], class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
