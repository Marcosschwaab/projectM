<div class="mb-6">
  <%= link_to organization_kpis_path(@organization), class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
    <%= t("actions.back_to_kpis") %>
  <% end %>
</div>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6 dark:text-gray-100"><%= t("kpis.new") %></h1>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
    <%= form_with(model: [@organization, @kpi], class: "space-y-4") do |f| %>
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.text_area :description, rows: 2, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :category, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.select :category, Kpi.categories.keys.map { |c| [c.humanize, c] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :frequency, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.select :frequency, Kpi.frequencies.keys.map { |f| [f.humanize, f] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-4">
        <div>
          <%= f.label :current_value, t("kpis.current_value"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :current_value, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :target_value, t("kpis.target_value"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.number_field :target_value, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
        <div>
          <%= f.label :unit, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
          <%= f.text_field :unit, placeholder: t("kpis.unit_placeholder"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
        </div>
      </div>
      <div>
        <%= f.label :project_id, t("kpis.project"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.collection_select :project_id, @organization.projects.active.order(:name), :id, :name, { include_blank: t("kpis.org_wide_no_project") }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.label :owner_id, t("kpis.owner"), class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.collection_select :owner_id, @organization.members, :id, :name, { include_blank: t("projects.unassigned") }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div class="flex items-center gap-3 pt-2">
        <%= f.submit t("kpis.create"), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 cursor-pointer border-none dark:bg-indigo-500 dark:hover:bg-indigo-600" %>
        <%= link_to t("actions.cancel"), organization_kpis_path(@organization), class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" %>
      </div>
    <% end %>
  </div>
</div>
