<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 dark:bg-gray-800 dark:border-gray-700">
  <h2 class="text-lg font-semibold text-gray-900 mb-4 dark:text-gray-100"><%= t("risks.matrix.title") %></h2>

  <div class="overflow-x-auto">
    <table class="w-full max-w-md mx-auto border-collapse">
      <caption class="text-xs text-gray-400 mb-2 text-center dark:text-gray-500"><%= t("risks.matrix.probability_vs_impact") %></caption>
      <thead>
        <tr>
          <th class="p-1"></th>
          <% (1..5).each do |i| %>
            <th class="p-1 text-center text-[10px] font-medium text-gray-400 uppercase dark:text-gray-500"><%= t("risks.matrix.very_low") %><br><span class="text-xs"><%= i %></span></th>
          <% end %>
        </tr>
        <tr><td colspan="6" class="border-t border-gray-200 dark:border-gray-700"></td></tr>
      </thead>
      <tbody>
        <% (1..5).reverse_each do |prob| %>
          <tr>
            <td class="p-1 text-right text-[10px] font-medium text-gray-400 pr-2 dark:text-gray-500 w-8"><%= prob %></td>
            <% (1..5).each do |imp| %>
              <% severity = prob * imp %>
              <% cell_color = severity >= 12 ? "bg-red-500" : severity >= 7 ? "bg-orange-400" : severity >= 4 ? "bg-yellow-300 dark:bg-yellow-500" : "bg-green-300 dark:bg-green-500" %>
              <% risks_at_cell = risks.select { |r| r.probability == prob && r.impact == imp } %>
              <td class="p-1">
                <div class="<%= cell_color %> rounded-lg <%= risks_at_cell.any? ? 'ring-2 ring-indigo-400 dark:ring-indigo-500' : 'opacity-40' %> min-h-[2rem] min-w-[2rem] flex items-center justify-center">
                  <% if risks_at_cell.any? %>
                    <span class="text-white text-[10px] font-bold"><%= risks_at_cell.size %></span>
                  <% end %>
                </div>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex items-center justify-center gap-4 mt-4 text-xs text-gray-500 dark:text-gray-400">
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-green-300 dark:bg-green-500 inline-block"></span> <%= t("risks.severity_levels.low") %></span>
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-yellow-300 dark:bg-yellow-500 inline-block"></span> <%= t("risks.severity_levels.medium") %></span>
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-orange-400 inline-block"></span> <%= t("risks.severity_levels.high") %></span>
    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-red-500 inline-block"></span> <%= t("risks.severity_levels.critical") %></span>
  </div>
</div>