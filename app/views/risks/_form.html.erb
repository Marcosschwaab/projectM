<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
  <%= form_with(model: [@organization, @project, risk], class: "space-y-4") do |f| %>
    <% if risk.errors.any? %>
      <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm dark:bg-red-900/30 dark:border-red-800 dark:text-red-400">
        <h2 class="font-semibold mb-1"><%= pluralize(risk.errors.count, t("errors.error", count: risk.errors.count)) %></h2>
        <ul class="list-disc pl-4 space-y-1">
          <% risk.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
      <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :probability, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.select :probability, (1..5).map { |p| [t("risks.probability.#{Risk.new(probability: p).probability_label}"), p] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.label :impact, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.select :impact, (1..5).map { |i| [t("risks.impact.#{Risk.new(impact: i).impact_label}"), i] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.select :status, Risk::STATUSES.map { |s| [t("risks.statuses.#{s}"), s] }, {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div data-controller="searchable-select" data-searchable-select-placeholder-value="<%= t("tasks.search_members") %>">
        <%= f.label :owner_id, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
        <%= f.collection_select :owner_id, @organization.members, :id, :name, { include_blank: t("projects.unassigned") }, data: { searchable_select_target: "select" }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
    </div>

    <div>
      <%= f.label :mitigation_plan, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
      <%= f.text_area :mitigation_plan, rows: 3, placeholder: t("risks.plan_tabs.no_mitigation"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
    </div>

    <div>
      <%= f.label :contingency_plan, class: "block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300" %>
      <%= f.text_area :contingency_plan, rows: 3, placeholder: t("risks.plan_tabs.no_contingency"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 cursor-pointer border-none dark:bg-indigo-500 dark:hover:bg-indigo-600" %>
      <%= link_to t("actions.cancel"), organization_project_risks_path(@organization, @project), class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" %>
    </div>
  <% end %>
</div>