<!DOCTYPE html>
<html data-controller="theme" data-theme-theme-value="<%= current_user&.theme || 'system' %>">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased dark:bg-gray-900 dark:text-gray-100"
        data-controller="<%= 'sidebar' if user_signed_in? %>">
    <% if user_signed_in? %>
      <div class="flex h-screen">
        <div data-sidebar-target="backdrop"
             data-action="click->sidebar#close"
             class="fixed inset-0 bg-black/30 z-40 hidden opacity-0 transition-opacity duration-300 lg:hidden"></div>

        <div data-sidebar-target="sidebar"
             class="max-lg:fixed max-lg:inset-y-0 max-lg:left-0 max-lg:z-50 -translate-x-full transition-transform duration-300 lg:relative lg:translate-x-0 lg:flex">
          <%= render "shared/sidebar" %>
        </div>

        <div class="flex-1 flex flex-col overflow-hidden min-w-0">
          <%= render "shared/topbar" %>

          <main class="flex-1 overflow-y-auto p-6">
            <% if notice %>
              <div class="mb-4 px-4 py-3 bg-green-100/80 text-green-800 rounded-lg text-sm dark:bg-green-900/40 dark:text-green-300"><%= notice %></div>
            <% end %>
            <% if alert %>
              <div class="mb-4 px-4 py-3 bg-red-100/80 text-red-800 rounded-lg text-sm dark:bg-red-900/40 dark:text-red-300"><%= alert %></div>
            <% end %>
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
        <div class="w-full max-w-md">
          <% if notice %>
            <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-700 rounded-lg text-sm dark:bg-green-900/30 dark:border-green-800 dark:text-green-400"><%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm dark:bg-red-900/30 dark:border-red-800 dark:text-red-400"><%= alert %></div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    <% end %>
    <%= render "shared/slideover" %>
  </body>
</html>
