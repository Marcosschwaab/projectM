<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("tags.title") %></h1>
  <%= link_to new_organization_tag_path(@organization), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:bg-indigo-500 dark:hover:bg-indigo-600" do %>
    + <%= t("tags.new") %>
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
  <table class="w-full">
    <thead>
      <tr class="bg-gray-50 dark:bg-gray-700">
        <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tags.fields.name") %></th>
        <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tags.fields.color") %></th>
        <th class="text-right px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tags.fields.actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
      <% @tags.each do |tag| %>
        <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-gray-700/50">
          <td class="px-6 py-4">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: <%= tag.color %>"></span>
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= tag.name %></span>
            </div>
          </td>
          <td class="px-6 py-4">
            <code class="text-xs text-gray-500 dark:text-gray-400"><%= tag.color %></code>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-3">
              <%= link_to t("actions.edit"), edit_organization_tag_path(@organization, tag), class: "text-xs text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %>
              <%= button_to t("actions.delete"), organization_tag_path(@organization, tag), method: :delete, data: { turbo_confirm: t("actions.confirm_delete") }, class: "text-xs text-red-600 hover:text-red-700 bg-transparent border-none cursor-pointer dark:text-red-400 dark:hover:text-red-300" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @tags.empty? %>
    <div class="p-8 text-center">
      <p class="text-gray-500 dark:text-gray-400"><%= t("tags.no_tags") %></p>
    </div>
  <% end %>
</div>
