<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-200 dark:border-gray-700">
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-600 dark:text-gray-400"><%= t("tasks.fields.title") %></th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-600 dark:text-gray-400"><%= t("tags.title") %></th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-600 dark:text-gray-400"><%= t("tasks.fields.status") %></th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-600 dark:text-gray-400"><%= t("tasks.fields.priority") %></th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-600 dark:text-gray-400"><%= t("tasks.fields.due_date") %></th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-600 dark:text-gray-400"><%= t("my_tasks.project") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
      <% @tasks.each do |task| %>
        <tr class="hover:bg-gray-50/80 transition-colors dark:hover:bg-gray-700/30 group">
          <td class="px-5 py-3.5">
            <div class="flex items-center gap-2">
              <div class="w-1 h-8 rounded-full flex-shrink-0 <%= project_color(task.project) %>"></div>
              <div class="min-w-0">
                <%= link_to [task.project.organization, task.project, task], class: "text-sm font-medium text-gray-900 hover:text-indigo-600 dark:text-gray-100 dark:hover:text-indigo-400 truncate block" do %>
                  <%= task.title %>
                <% end %>
              </div>
              <% if task.recurring? %>
                <svg class="w-3.5 h-3.5 text-indigo-400 dark:text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              <% end %>
            </div>
          </td>
          <td class="px-5 py-3.5">
            <% if task.tags.any? %>
              <div class="flex items-center gap-1 flex-wrap">
                <% task.tags.each do |tag| %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium leading-tight" style="background-color: <%= tag.color %>18; color: <%= tag.color %>">
                    <%= tag.name %>
                  </span>
                <% end %>
              </div>
            <% else %>
              <span class="text-xs text-gray-300 dark:text-gray-600">—</span>
            <% end %>
          </td>
          <td class="px-5 py-3.5">
            <%= status_badge(task.status) %>
          </td>
          <td class="px-5 py-3.5">
            <%= priority_badge(task.priority) %>
          </td>
          <td class="px-5 py-3.5 text-sm <%= task.due_date && task.due_date < Date.today && task.status != "done" ? "text-red-600 font-medium dark:text-red-400" : "text-gray-500 dark:text-gray-400" %>">
            <% if task.due_date %>
              <span class="inline-flex items-center gap-1.5">
                <% if task.due_date < Date.today && task.status != "done" %>
                  <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <% end %>
                <%= task.due_date.strftime("%b %d") %>
              </span>
            <% else %>
              <span class="text-gray-300 dark:text-gray-600">—</span>
            <% end %>
          </td>
          <td class="px-5 py-3.5">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full <%= project_color(task.project) %> flex-shrink-0"></span>
              <%= link_to task.project.name, [task.project.organization, task.project], class: "text-sm text-gray-500 hover:text-indigo-600 dark:text-gray-400 dark:hover:text-indigo-400 truncate max-w-[120px] block" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
