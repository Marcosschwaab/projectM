<div class="mb-8">
  <div class="flex items-center justify-between flex-wrap gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("my_tasks.title") %></h1>
      <p class="text-sm text-gray-500 mt-1 dark:text-gray-400"><%= t("my_tasks.subtitle", count: @total_count) %></p>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs text-gray-500 dark:text-gray-400"><%= t("my_tasks.group_by") %>:</span>
      <div class="flex items-center gap-1 bg-gray-100 dark:bg-gray-700 rounded-lg p-0.5">
        <%= group_link(@group_by, nil, t("my_tasks.table")) %>
        <%= group_link(@group_by, "project", t("my_tasks.project")) %>
        <%= group_link(@group_by, "priority", t("tasks.fields.priority")) %>
        <%= group_link(@group_by, "status", t("tasks.fields.status")) %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-3 gap-3 mt-5">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("my_tasks.total") %></p>
          <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= @total_count %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-green-50 dark:bg-green-900/30 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("my_tasks.done") %></p>
          <p class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= @done_count %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-red-50 dark:bg-red-900/30 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("my_tasks.overdue") %></p>
          <p class="text-xl font-bold text-red-600 dark:text-red-400"><%= @overdue_count %></p>
        </div>
      </div>
    </div>
  </div>

  <%= render "my_tasks/filters" %>
</div>

<% if @tasks.empty? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center dark:bg-gray-800 dark:border-gray-700">
    <svg class="mx-auto w-12 h-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
    </svg>
    <p class="mt-3 text-sm text-gray-500 dark:text-gray-400"><%= t("my_tasks.empty") %></p>
    <p class="text-xs text-gray-400 mt-1 dark:text-gray-500"><%= t("my_tasks.empty_hint") %></p>
  </div>
<% elsif @group_by && @grouped_tasks %>
  <%= render "my_tasks/grouped_view", grouped_tasks: @grouped_tasks %>
<% else %>
  <%= render "my_tasks/table_view" %>
<% end %>
