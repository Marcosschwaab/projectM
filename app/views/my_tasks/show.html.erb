<div class="mb-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("my_tasks.title") %></h1>
      <p class="text-sm text-gray-500 mt-1 dark:text-gray-400"><%= t("my_tasks.subtitle", count: @total_count) %></p>
    </div>
  </div>

  <div class="flex items-center gap-4 mt-4">
    <div class="flex items-center gap-2 text-sm">
      <span class="w-3 h-3 rounded-full bg-indigo-500"></span>
      <span class="text-gray-600 dark:text-gray-400"><%= t("my_tasks.total") %>: <strong><%= @total_count %></strong></span>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <span class="w-3 h-3 rounded-full bg-green-500"></span>
      <span class="text-gray-600 dark:text-gray-400"><%= t("my_tasks.done") %>: <strong><%= @done_count %></strong></span>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <span class="w-3 h-3 rounded-full bg-red-500"></span>
      <span class="text-gray-600 dark:text-gray-400"><%= t("my_tasks.overdue") %>: <strong><%= @overdue_count %></strong></span>
    </div>
  </div>
</div>

<%= form_with url: my_tasks_path, method: :get, class: "mb-6" do |f| %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 dark:bg-gray-800 dark:border-gray-700">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div>
        <%= f.search_field :q, value: params[:q], placeholder: t("tasks.filters.search"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.select :project_id, options_from_collection_for_select(@projects, :id, :name, params[:project_id]), { include_blank: t("my_tasks.all_projects") }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.select :priority, options_for_select(Task.priorities.keys.map { |k| [k.humanize, k] }, params[:priority]), { include_blank: t("tasks.filters.all_priorities") }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.select :status, options_for_select(Task.statuses.keys.map { |k| [k.humanize, k] }, params[:status]), { include_blank: t("tasks.filters.all_statuses") }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.date_field :due_date_from, value: params[:due_date_from], placeholder: t("tasks.filters.due_from"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
      <div>
        <%= f.date_field :due_date_to, value: params[:due_date_to], placeholder: t("tasks.filters.due_to"), class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-gray-200" %>
      </div>
    </div>
    <div class="flex items-center gap-2 mt-3">
      <%= f.submit t("actions.filter"), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer dark:bg-indigo-500 dark:hover:bg-indigo-600" %>
      <%= link_to t("actions.clear"), my_tasks_path, class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg text-sm hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50" %>
    </div>
  </div>
<% end %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
  <table class="w-full">
    <thead>
      <tr class="bg-gray-50 dark:bg-gray-700">
        <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tasks.fields.title") %></th>
        <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("my_tasks.project") %></th>
        <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tasks.fields.status") %></th>
        <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tasks.fields.priority") %></th>
        <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tasks.fields.due_date") %></th>
        <th class="text-right px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400"><%= t("tasks.filters.actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
      <% @tasks.each do |task| %>
        <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-gray-700/50">
          <td class="px-6 py-4">
            <div class="flex items-center gap-2">
              <%= link_to [task.project.organization, task.project, task], class: "text-sm font-medium text-gray-900 hover:text-indigo-600 dark:text-gray-100 dark:hover:text-indigo-400" do %>
                <%= task.title %>
              <% end %>
              <% task.tags.each do |tag| %>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>">
                  <%= tag.name %>
                </span>
              <% end %>
            </div>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
            <%= link_to task.project.name, [task.project.organization, task.project], class: "hover:text-indigo-600 dark:hover:text-indigo-400" %>
          </td>
          <td class="px-6 py-4">
            <span class="<%= status_badge_class(task.status) %>"><%= task.status&.humanize %></span>
          </td>
          <td class="px-6 py-4">
            <span class="<%= priority_class(task.priority) %>"><%= task.priority&.humanize %></span>
          </td>
          <td class="px-6 py-4 text-sm <%= task.due_date && task.due_date < Date.today && task.status != "done" ? "text-red-600 font-medium dark:text-red-400" : "text-gray-600 dark:text-gray-400" %>">
            <%= task.due_date || "-" %>
          </td>
          <td class="px-6 py-4 text-right">
            <%= link_to t("actions.view"), [task.project.organization, task.project, task], class: "text-xs text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @tasks.empty? %>
    <div class="p-8 text-center">
      <svg class="mx-auto w-12 h-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
      </svg>
      <p class="mt-3 text-sm text-gray-500 dark:text-gray-400"><%= t("my_tasks.empty") %></p>
      <p class="text-xs text-gray-400 mt-1 dark:text-gray-500"><%= t("my_tasks.empty_hint") %></p>
    </div>
  <% end %>
</div>
