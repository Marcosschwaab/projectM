<div class="space-y-5">
  <% grouped_tasks.each do |group_key, group_tasks| %>
    <% done_count = group_tasks.count { |t| t.status == "done" } %>
    <% overdue_count = group_tasks.count { |t| t.due_date && t.due_date < Date.today && t.status != "done" } %>
    <% progress_pct = group_tasks.size > 0 ? (done_count.to_f / group_tasks.size * 100).round : 0 %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700"
         data-controller="collapse">
      <button data-action="click->collapse#toggle"
              class="w-full px-5 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors dark:hover:bg-gray-700/50 text-left group">
        <div class="flex items-center gap-3 min-w-0">
          <svg class="w-4 h-4 text-gray-400 transition-transform duration-200 dark:text-gray-500 flex-shrink-0" data-collapse-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-sm font-semibold text-gray-900 dark:text-gray-100">
                <%= group_label(group_key, @group_by) %>
              </span>
              <span class="text-xs bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 px-2 py-0.5 rounded-full font-medium"><%= group_tasks.size %></span>
            </div>
            <div class="flex items-center gap-2.5 mt-1">
              <div class="w-24 h-1.5 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-500 <%= progress_pct == 100 ? 'bg-green-500' : progress_pct > 0 ? 'bg-indigo-500' : 'bg-gray-200 dark:bg-gray-600' %>" style="width: <%= progress_pct %>%"></div>
              </div>
              <span class="text-[10px] text-gray-400 dark:text-gray-500"><%= progress_pct %>%</span>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-3 text-xs flex-shrink-0 ml-3">
          <span class="text-gray-500 dark:text-gray-400"><%= done_count %>/<%= group_tasks.size %> <%= t("my_tasks.done").downcase %></span>
          <% if overdue_count > 0 %>
            <span class="text-red-500 font-medium"><%= overdue_count %> <%= t("my_tasks.overdue").downcase %></span>
          <% end %>
        </div>
      </button>
      <div data-collapse-target="body">
        <div class="divide-y divide-gray-100 dark:divide-gray-700">
          <% group_tasks.each do |task| %>
            <div class="px-5 py-3.5 flex items-center justify-between hover:bg-gray-50/80 transition-colors dark:hover:bg-gray-700/30 group">
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div class="w-1 h-8 rounded-full flex-shrink-0 <%= task.due_date && task.due_date < Date.today && task.status != "done" ? 'bg-red-500' : project_color(task.project) %>"></div>
                <div class="min-w-0 flex-1">
                  <%= link_to [task.project.organization, task.project, task], class: "text-sm font-medium text-gray-900 hover:text-indigo-600 dark:text-gray-100 dark:hover:text-indigo-400 truncate block" do %>
                    <%= task.title %>
                  <% end %>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-xs text-gray-400 dark:text-gray-500"><%= task.project.name %></span>
                    <% task.tags.each do |tag| %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium leading-tight" style="background-color: <%= tag.color %>18; color: <%= tag.color %>"><%= tag.name %></span>
                    <% end %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-2.5 flex-shrink-0 ml-3">
                <% if task.due_date %>
                  <span class="text-xs font-medium px-2 py-0.5 rounded <%= task.due_date < Date.today && task.status != "done" ? "bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-400" : task.due_date <= 3.days.from_now && task.status != "done" ? "bg-amber-50 text-amber-600 dark:bg-amber-900/30 dark:text-amber-400" : "bg-gray-50 text-gray-500 dark:bg-gray-700 dark:text-gray-400" %>">
                  <%= task.due_date.strftime("%b %d") %>
                </span>
                <% end %>
                <%= status_badge(task.status) %>
                <%= link_to t("actions.view"), [task.project.organization, task.project, task], class: "text-xs text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300 ml-1 opacity-0 group-hover:opacity-100 transition-opacity" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
