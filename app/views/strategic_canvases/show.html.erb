<%= render "shared/project_nav" %>

<div class="flex items-center justify-between mb-2">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("strategic_canvas.title") %></h1>
  </div>
  <button form="canvas-form" class="px-5 py-2.5 bg-indigo-600 text-white font-medium rounded-lg text-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors cursor-pointer dark:bg-indigo-500 dark:hover:bg-indigo-600">
    <span class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      <%= t("strategic_canvas.save") %>
    </span>
  </button>
</div>

<%= form_with(model: @canvas, url: organization_project_strategic_canvas_path(@organization, @project), method: :patch, id: "canvas-form", data: { turbo: false }) do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
    <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.problem") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :problem, rows: 5, placeholder: t("strategic_canvas.problem_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500", style: "min-height: 100px" %>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.goal") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :goal, rows: 5, placeholder: t("strategic_canvas.goal_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500", style: "min-height: 100px" %>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden sm:col-span-2 dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.value_proposition") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :value_proposition, rows: 3, placeholder: t("strategic_canvas.value_proposition_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500" %>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.metrics") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :metrics, rows: 5, placeholder: t("strategic_canvas.metrics_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500", style: "min-height: 100px" %>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.stakeholders") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :stakeholders, rows: 5, placeholder: t("strategic_canvas.stakeholders_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500", style: "min-height: 100px" %>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.team") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :team, rows: 4, placeholder: t("strategic_canvas.team_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500" %>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.risks") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :risks, rows: 4, placeholder: t("strategic_canvas.risks_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500" %>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.resources") %></h3>
          </div>
        </div>
        <div class="p-4">
          <%= f.text_area :resources, rows: 4, placeholder: t("strategic_canvas.resources_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500" %>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
      <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.roadmap") %></h3>
        </div>
      </div>
      <div class="p-4">
        <%= f.text_area :roadmap, rows: 4, placeholder: t("strategic_canvas.roadmap_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500" %>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
      <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 dark:bg-gray-700/50 dark:border-gray-700">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300"><%= t("strategic_canvas.next_steps") %></h3>
        </div>
      </div>
      <div class="p-4">
        <%= f.text_area :next_steps, rows: 4, placeholder: t("strategic_canvas.next_steps_placeholder"), class: "w-full text-sm text-gray-700 bg-transparent border-none resize-none focus:outline-none placeholder:text-gray-300 dark:text-gray-300 dark:placeholder:text-gray-500" %>
      </div>
    </div>
  </div>
<% end %>
