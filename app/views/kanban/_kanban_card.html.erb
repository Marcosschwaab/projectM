<% done = task.status == "done" %>
<% status_color = case task.status
  when "done" then "border-l-emerald-500"
  when "in_review" then "border-l-violet-500"
  when "in_progress" then "border-l-blue-500"
  when "todo" then "border-l-gray-400"
  when "backlog" then "border-l-gray-300"
  else "border-l-gray-300"
end %>

<div class="kanban-card bg-white rounded-lg shadow-sm border border-gray-200 border-l-[3px] <%= status_color %> p-3 cursor-grab hover:shadow-md hover:-translate-y-0.5 dark:bg-gray-800 dark:border-gray-700 dark:hover:shadow-gray-900/40 <%= "opacity-60" if done %>"
     data-task-id="<%= task.id %>"
     draggable="true">
  <div class="flex items-start justify-between mb-2">
    <div class="flex items-center gap-2 min-w-0 flex-1">
      <% if done %>
        <svg class="w-4 h-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
      <% end %>
      <%= link_to "#",
                  class: "min-w-0",
                  data: { url: modal_organization_project_task_path(task.project.organization, task.project, task), action: "slideover#open", modal_title: task.title } do %>
        <h4 class="text-sm font-medium text-gray-900 truncate dark:text-gray-100 <%= "line-through text-gray-400 dark:text-gray-500" if done %>"><%= task.title %></h4>
      <% end %>
    </div>
  </div>

  <% if task.tags.any? %>
    <div class="flex items-center gap-1 mb-2 flex-wrap">
      <% task.tags.each do |tag| %>
        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium leading-tight" style="background-color: <%= tag.color %>18; color: <%= tag.color %>">
          <%= tag.name %>
        </span>
      <% end %>
    </div>
  <% end %>

  <div class="flex items-center gap-2 mb-2 flex-wrap">
    <%= priority_badge(task.priority) %>
    <% if task.due_date %>
      <span class="text-xs <%= task.due_date < Date.today ? "text-red-500 font-medium dark:text-red-400" : "text-gray-400 dark:text-gray-500" %>">
        <%= l(task.due_date, format: :short) %>
      </span>
    <% end %>
  </div>

  <% if task.checklist_items.any? %>
    <% completed = task.checklist_items.count(&:completed) %>
    <% total = task.checklist_items.size %>
    <div class="mb-2">
      <div class="flex items-center justify-between text-xs text-gray-400 dark:text-gray-500 mb-1">
        <span><%= completed %>/<%= total %></span>
      </div>
      <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
        <div class="h-full rounded-full transition-all duration-300 <%= completed == total ? "bg-emerald-500" : "bg-indigo-500" %>" style="width: <%= total > 0 ? (completed.to_f / total * 100) : 0 %>%"></div>
      </div>
    </div>
  <% end %>

  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <% if task.recurring? %>
        <span class="text-xs text-indigo-400 dark:text-indigo-500 flex items-center gap-0.5" title="<%= task.recurrence_label %>">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        </span>
      <% end %>
      <% if task.assignee %>
        <div class="w-5 h-5 rounded-full bg-indigo-100 flex items-center justify-center dark:bg-indigo-900/40">
          <span class="text-[10px] font-semibold text-indigo-600 dark:text-indigo-400"><%= task.assignee.name.first.upcase %></span>
        </div>
      <% end %>
      <% if task.dependencies.any? %>
        <span class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-0.5" title="<%= t("tasks.depends_on") %>">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          <%= task.dependencies.size %>
        </span>
      <% end %>
      <% if task.files.any? %>
        <span class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-0.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
          <%= task.files.size %>
        </span>
      <% end %>
    </div>
  </div>
</div>
