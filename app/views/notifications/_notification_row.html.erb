<div class="flex items-start gap-3 px-5 py-4 <%= unread ? "bg-indigo-50/30 dark:bg-indigo-900/20" : "hover:bg-gray-50 dark:hover:bg-gray-700/50" %> transition-colors <%= "cursor-pointer" if unread %>"
     data-controller="notification"
     data-action="click->notification#markRead"
     data-notification-id="<%= notification.id %>"
     data-notification-read-url="<%= mark_read_notification_path(notification) %>"
   data-notification-mark-read-url="<%= mark_read_notification_path(notification) %>">
  <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 <%= unread ? "bg-indigo-100 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400" : "bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400" %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <% case notification.action %>
      <% when "task_assigned" %>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
      <% when "task_commented" %>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
      <% when "task_moved" %>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
      <% else %>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
      <% end %>
    </svg>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-sm <%= unread ? "font-semibold text-gray-900 dark:text-gray-100" : "text-gray-700 dark:text-gray-300" %>">
      <% if notification.actor %>
        <strong><%= notification.actor.name %></strong>
      <% end %>
      <%= notification.description %>
      <% if notification.notifiable.respond_to?(:title) %>
        <strong><%= notification.notifiable.title %></strong>
      <% elsif notification.notifiable.respond_to?(:name) %>
        <strong><%= notification.notifiable.name %></strong>
      <% end %>
    </p>
    <div class="flex items-center gap-2 mt-0.5">
      <span class="text-xs text-gray-400 dark:text-gray-500"><%= t("time.ago", time: time_ago_in_words(notification.created_at)) %></span>
      <% if unread %>
        <span class="w-1.5 h-1.5 bg-indigo-600 rounded-full dark:bg-indigo-400"></span>
      <% end %>
    </div>
  </div>
</div>
