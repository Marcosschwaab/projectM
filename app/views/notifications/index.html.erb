<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("notifications.title") %></h1>
  <% if @unread.any? %>
    <%= button_to mark_all_read_notifications_path, method: :patch, class: "px-4 py-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 border border-indigo-200 rounded-lg hover:bg-indigo-50 cursor-pointer dark:text-indigo-400 dark:hover:text-indigo-300 dark:border-indigo-700 dark:hover:bg-indigo-900/30" do %>
      <%= t("actions.mark_all_read") %>
    <% end %>
  <% end %>
</div>

<% if @notifications.empty? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center dark:bg-gray-800 dark:border-gray-700">
    <svg class="w-12 h-12 text-gray-300 mx-auto mb-3 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
    <p class="text-gray-500 dark:text-gray-400"><%= t("notifications.empty") %></p>
  </div>
<% else %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-700">
    <% @unread.each do |notification| %>
      <%= render "notification_row", notification: notification, unread: true %>
    <% end %>
    <% @read.each do |notification| %>
      <%= render "notification_row", notification: notification, unread: false %>
    <% end %>
  </div>
<% end %>
